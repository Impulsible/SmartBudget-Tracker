@page "/budgets"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject IJSRuntime JS

<PageTitle>SmartBudget - Budgets</PageTitle>

<div class="tx-layout">
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <a href="/dashboard" class="sidebar-logo">
                <div class="sidebar-logo-icon"><i class="bi bi-piggy-bank"></i></div>
                <span class="sidebar-logo-text">Smart<span>Budget</span></span>
            </a>
            <button class="sidebar-close-btn" id="sidebarCloseBtn"><i class="bi bi-x-lg"></i></button>
        </div>
        <nav class="sidebar-nav">
            <div class="nav-section">
                <span class="nav-section-title">Main Menu</span>
                <a href="/dashboard" class="nav-item"><i class="bi bi-speedometer2"></i><span>Dashboard</span></a>
                <a href="/transactions" class="nav-item"><i class="bi bi-arrow-left-right"></i><span>Transactions</span></a>
                <a href="/budgets" class="nav-item active"><i class="bi bi-pie-chart"></i><span>Budgets</span></a>
                <a href="/goals" class="nav-item"><i class="bi bi-flag"></i><span>Goals</span></a>
            </div>
            <div class="nav-section">
                <span class="nav-section-title">Tools</span>
                <a href="/reports" class="nav-item"><i class="bi bi-file-earmark-bar-graph"></i><span>Reports</span></a>
                <a href="/export" class="nav-item"><i class="bi bi-download"></i><span>Export Data</span></a>
                <a href="/settings" class="nav-item"><i class="bi bi-gear"></i><span>Settings</span></a>
            </div>
        </nav>
        <div class="sidebar-footer">
            <div class="sidebar-user-info">
                <span class="sidebar-user-name">SmartBudget</span>
                <span class="sidebar-version">v1.0</span>
            </div>
            <a href="/Account/Logout" class="sidebar-logout" title="Logout"><i class="bi bi-box-arrow-right"></i></a>
        </div>
    </aside>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- Main Content -->
    <main class="main-content">
        <header class="dashboard-header">
            <div class="header-left">
                <button class="sidebar-toggle-btn" id="sidebarToggleBtn"><i class="bi bi-list"></i></button>
                <div class="header-greeting">
                    <h2>Budget Management</h2>
                    <p>Set and manage your spending limits</p>
                </div>
            </div>
            <div class="header-right">
                <button class="btn-add-transaction" onclick="openBudgetModal()">
                    <i class="bi bi-plus-lg"></i> Add Budget
                </button>
            </div>
        </header>

        <div class="tx-body">
            <!-- Budget Summary -->
            <div class="tx-stats-row" id="budgetStatsRow">
                <div class="tx-stat income">
                    <span class="tx-stat-label">Total Budget</span>
                    <span class="tx-stat-value" id="budgetTotal">₦0</span>
                </div>
                <div class="tx-stat expense">
                    <span class="tx-stat-label">Total Spent</span>
                    <span class="tx-stat-value" id="budgetSpent">₦0</span>
                </div>
                <div class="tx-stat balance">
                    <span class="tx-stat-label">Remaining</span>
                    <span class="tx-stat-value" id="budgetRemaining">₦0</span>
                </div>
                <div class="tx-stat count">
                    <span class="tx-stat-label">Categories</span>
                    <span class="tx-stat-value" id="budgetCount">0</span>
                </div>
            </div>

            <!-- Budget Cards -->
            <div class="budget-grid" id="budgetGrid"></div>
        </div>

        <!-- Footer -->
        <footer class="tx-footer">
            <div class="tx-footer-content">
                <p>&copy; @DateTime.Now.Year SmartBudget. All rights reserved.</p>
                <div class="tx-footer-links">
                    <a href="/privacy">Privacy</a>
                    <a href="/terms">Terms</a>
                    <a href="/contact">Contact</a>
                </div>
            </div>
        </footer>
    </main>
</div>

<!-- Add/Edit Budget Modal -->
<div class="modal-overlay" id="budgetModal" style="display:none;">
    <div class="modal-content">
        <div class="modal-header">
            <h3 id="budgetModalTitle">Add Budget Category</h3>
            <button class="modal-close" onclick="closeBudgetModal()"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="budgetId" />
            <div class="form-group">
                <label>Category Name</label>
                <input type="text" class="form-control" id="budgetName" placeholder="e.g., Food & Groceries" />
            </div>
            <div class="form-group">
                <label>Budget Amount (₦)</label>
                <input type="number" class="form-control" id="budgetAmount" placeholder="0.00" step="0.01" min="0" />
            </div>
            <div class="form-group">
                <label>Color</label>
                <select class="form-control" id="budgetColor">
                    <option value="#10B981">🟢 Green</option>
                    <option value="#3B82F6">🔵 Blue</option>
                    <option value="#F59E0B">🟡 Amber</option>
                    <option value="#EF4444">🔴 Red</option>
                    <option value="#8B5CF6">🟣 Purple</option>
                    <option value="#EC4899">🩷 Pink</option>
                    <option value="#06B6D4">🩵 Cyan</option>
                    <option value="#F97316">🟠 Orange</option>
                    <option value="#14B8A6">🟢 Teal</option>
                    <option value="#6366F1">🔵 Indigo</option>
                </select>
            </div>
            <div id="budgetColorPreview" style="background:#10B981;width:40px;height:40px;border-radius:8px;margin-top:0.5rem;border:2px solid rgba(148,163,184,0.2);transition:background 0.2s;"></div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeBudgetModal()">Cancel</button>
            <button class="btn-save" onclick="saveBudget()">Save Budget</button>
        </div>
    </div>
</div>

<style>
    :root {
        --sidebar-width: 260px;
        --header-height: 70px;
        --brand: #10B981;
        --brand-dark: #059669;
        --bg-dashboard: #0F172A;
        --bg-sidebar: #0B1120;
        --bg-card: #1E293B;
        --text-primary: #F1F5F9;
        --text-secondary: #94A3B8;
        --text-muted: #64748B;
        --border-color: rgba(148, 163, 184, 0.1);
        --income-color: #10B981;
        --expense-color: #EF4444;
    }
    
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { width: 100%; overflow-x: hidden; }
    
    .tx-layout {
        display: flex;
        min-height: 100vh;
        background: var(--bg-dashboard);
        font-family: 'Inter', sans-serif;
        color: var(--text-primary);
    }
    
    /* ===== SIDEBAR ===== */
    .sidebar {
        position: fixed;
        top: 0;
        left: 0;
        bottom: 0;
        width: var(--sidebar-width);
        background: var(--bg-sidebar);
        border-right: 1px solid var(--border-color);
        display: flex;
        flex-direction: column;
        z-index: 100;
        transition: transform 0.3s;
        overflow-y: auto;
    }
    
    .sidebar-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--border-color);
    }
    
    .sidebar-logo {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        text-decoration: none;
    }
    
    .sidebar-logo-icon {
        width: 38px;
        height: 38px;
        background: linear-gradient(135deg, var(--brand), var(--brand-dark));
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .sidebar-logo-icon i { font-size: 20px; color: white; }
    
    .sidebar-logo-text {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--text-primary);
    }
    
    .sidebar-logo-text span { color: var(--brand); }
    
    .sidebar-close-btn {
        display: none;
        background: none;
        border: none;
        color: var(--text-secondary);
        font-size: 1.5rem;
        cursor: pointer;
        padding: 0.25rem;
    }
    
    .sidebar-close-btn:hover { color: var(--text-primary); }
    
    .sidebar-nav { flex: 1; padding: 1.25rem 0.75rem; overflow-y: auto; }
    
    .nav-section { margin-bottom: 1.5rem; }
    
    .nav-section-title {
        display: block;
        font-size: 0.6875rem;
        font-weight: 600;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 0 1rem;
        margin-bottom: 0.5rem;
    }
    
    .nav-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.625rem 1rem;
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        border-radius: 8px;
        transition: all 0.15s;
        margin-bottom: 0.125rem;
    }
    
    .nav-item:hover {
        background: rgba(255, 255, 255, 0.04);
        color: var(--text-primary);
    }
    
    .nav-item.active {
        background: rgba(16, 185, 129, 0.1);
        color: var(--brand);
        font-weight: 600;
    }
    
    .nav-item i { font-size: 1.125rem; width: 22px; text-align: center; }
    
    .sidebar-footer {
        padding: 1rem 1.25rem;
        border-top: 1px solid var(--border-color);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
    }
    
    .sidebar-user-info { display: flex; flex-direction: column; }
    
    .sidebar-user-name {
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--text-primary);
    }
    
    .sidebar-version { font-size: 0.6875rem; color: var(--text-muted); }
    
    .sidebar-logout {
        color: var(--text-muted);
        font-size: 1.125rem;
        padding: 0.5rem;
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.15s;
    }
    
    .sidebar-logout:hover {
        color: var(--expense-color);
        background: rgba(239, 68, 68, 0.1);
    }
    
    .sidebar-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.6);
        z-index: 99;
    }
    
    .sidebar-overlay.open { display: block; }
    
    /* ===== MAIN CONTENT ===== */
    .main-content {
        flex: 1;
        margin-left: var(--sidebar-width);
        width: calc(100% - var(--sidebar-width));
        min-width: 0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }
    
    /* ===== HEADER ===== */
    .dashboard-header {
        position: sticky;
        top: 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 2rem;
        height: var(--header-height);
        background: rgba(15, 23, 42, 0.9);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border-color);
        z-index: 50;
    }
    
    .header-left { display: flex; align-items: center; gap: 1rem; }
    
    .sidebar-toggle-btn {
        display: none;
        background: none;
        border: none;
        color: var(--text-secondary);
        font-size: 1.5rem;
        cursor: pointer;
        padding: 0.25rem;
    }
    
    .sidebar-toggle-btn:hover { color: var(--text-primary); }
    
    .header-greeting h2 { font-size: 1.25rem; font-weight: 700; color: var(--text-primary); }
    
    .header-greeting p {
        font-size: 0.8125rem;
        color: var(--text-secondary);
        margin-top: 0.125rem;
    }
    
    .header-right { display: flex; align-items: center; gap: 1rem; }
    
    .btn-add-transaction {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        background: var(--brand);
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 0.8125rem;
        font-weight: 600;
        cursor: pointer;
        font-family: 'Inter', sans-serif;
        transition: all 0.15s;
    }
    
    .btn-add-transaction:hover {
        background: var(--brand-dark);
        transform: translateY(-1px);
    }
    
    /* ===== BODY ===== */
    .tx-body { flex: 1; padding: 1.5rem 2rem; }
    
    /* ===== STATS ===== */
    .tx-stats-row {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1.25rem;
        margin-bottom: 1.5rem;
    }
    
    .tx-stat {
        background: var(--bg-card);
        border-radius: 16px;
        padding: 1.25rem;
        border: 1px solid var(--border-color);
        text-align: center;
        transition: all 0.2s;
    }
    
    .tx-stat:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
    }
    
    .tx-stat-label {
        display: block;
        font-size: 0.75rem;
        color: var(--text-muted);
        text-transform: uppercase;
        margin-bottom: 0.5rem;
        letter-spacing: 0.05em;
    }
    
    .tx-stat-value {
        font-size: clamp(1.25rem, 3vw, 1.5rem);
        font-weight: 700;
        line-height: 1.2;
        overflow-wrap: anywhere;
    }
    
    .tx-stat.income .tx-stat-value { color: var(--income-color); }
    .tx-stat.expense .tx-stat-value { color: var(--expense-color); }
    .tx-stat.balance .tx-stat-value { color: #3B82F6; }
    .tx-stat.count .tx-stat-value { color: #F1F5F9; }
    
    /* ===== BUDGET GRID ===== */
    .budget-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1.25rem;
    }
    
    .budget-card {
        background: var(--bg-card);
        border-radius: 16px;
        padding: 1.25rem;
        border: 1px solid var(--border-color);
        transition: all 0.2s;
        position: relative;
        overflow: hidden;
    }
    
    .budget-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
    }
    
    .budget-card-color {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
    }
    
    .budget-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1rem;
        margin-top: 0.5rem;
        flex-wrap: wrap;
        gap: 0.5rem;
    }
    
    .budget-card-title {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-primary);
        word-break: break-word;
    }
    
    .budget-card-actions { display: flex; gap: 0.25rem; }
    
    .budget-card-amount {
        font-size: clamp(1.25rem, 4vw, 1.75rem);
        font-weight: 800;
        color: var(--text-primary);
        margin-bottom: 0.5rem;
        word-break: break-word;
    }
    
    .budget-card-spent {
        font-size: 0.8125rem;
        color: var(--text-secondary);
        margin-bottom: 0.75rem;
    }
    
    .budget-progress-bar {
        height: 6px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 3px;
        overflow: hidden;
        margin-bottom: 0.5rem;
    }
    
    .budget-progress-fill {
        height: 100%;
        border-radius: 3px;
        transition: width 0.5s ease;
    }
    
    .budget-progress-label {
        font-size: 0.75rem;
        color: var(--text-muted);
        text-align: right;
    }
    
    .budget-progress-label.over { color: var(--expense-color); font-weight: 600; }
    
    /* ===== BUTTONS ===== */
    .btn-edit-budget {
        background: rgba(59, 130, 246, 0.1);
        border: 1px solid rgba(59, 130, 246, 0.2);
        color: #3B82F6;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.875rem;
        transition: all 0.15s;
    }
    
    .btn-edit-budget:hover {
        background: rgba(59, 130, 246, 0.2);
        transform: scale(1.05);
    }
    
    .btn-delete-budget {
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.2);
        color: #EF4444;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.875rem;
        transition: all 0.15s;
    }
    
    .btn-delete-budget:hover {
        background: rgba(239, 68, 68, 0.2);
        transform: scale(1.05);
    }
    
    /* ===== FOOTER ===== */
    .tx-footer {
        background: var(--bg-sidebar);
        border-top: 1px solid var(--border-color);
        padding: 1.5rem 2rem;
        margin-top: auto;
    }
    
    .tx-footer-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }
    
    .tx-footer-content p { color: var(--text-muted); font-size: 0.8125rem; }
    
    .tx-footer-links { display: flex; gap: 1.5rem; }
    
    .tx-footer-links a {
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.8125rem;
        transition: color 0.15s;
    }
    
    .tx-footer-links a:hover { color: var(--brand); }
    
    /* ===== MODALS ===== */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.7);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 200;
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
        padding: 1rem;
    }
    
    .modal-content {
        background: var(--bg-card);
        border-radius: 20px;
        width: 100%;
        max-width: 480px;
        border: 1px solid var(--border-color);
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5);
        max-height: 90vh;
        overflow-y: auto;
    }
    
    .modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--border-color);
        position: sticky;
        top: 0;
        background: var(--bg-card);
        z-index: 1;
        border-radius: 20px 20px 0 0;
    }
    
    .modal-header h3 { font-size: 1.125rem; font-weight: 600; }
    
    .modal-close {
        background: none;
        border: none;
        color: var(--text-muted);
        font-size: 1.25rem;
        cursor: pointer;
        padding: 0.25rem;
        border-radius: 8px;
        transition: all 0.15s;
    }
    
    .modal-close:hover {
        color: var(--text-primary);
        background: rgba(255, 255, 255, 0.05);
    }
    
    .modal-body {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    
    .modal-body .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    
    .modal-body label {
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--text-secondary);
    }
    
    .modal-body .form-control {
        padding: 0.625rem 0.875rem;
        background: #0F172A;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        color: var(--text-primary);
        font-size: 0.875rem;
        font-family: 'Inter', sans-serif;
        width: 100%;
        transition: border-color 0.15s;
    }
    
    .modal-body .form-control:focus {
        outline: none;
        border-color: var(--brand);
        box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
    }
    
    .modal-footer {
        display: flex;
        justify-content: flex-end;
        gap: 0.75rem;
        padding: 1rem 1.5rem;
        border-top: 1px solid var(--border-color);
        position: sticky;
        bottom: 0;
        background: var(--bg-card);
        border-radius: 0 0 20px 20px;
    }
    
    .btn-cancel {
        padding: 0.625rem 1.25rem;
        background: none;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        color: var(--text-secondary);
        cursor: pointer;
        font-size: 0.875rem;
        font-weight: 500;
        font-family: 'Inter', sans-serif;
        transition: all 0.15s;
    }
    
    .btn-cancel:hover {
        background: rgba(255, 255, 255, 0.05);
        color: var(--text-primary);
    }
    
    .btn-save {
        padding: 0.625rem 1.5rem;
        background: var(--brand);
        border: none;
        border-radius: 8px;
        color: white;
        cursor: pointer;
        font-size: 0.875rem;
        font-weight: 600;
        font-family: 'Inter', sans-serif;
        transition: all 0.15s;
    }
    
    .btn-save:hover {
        background: var(--brand-dark);
        transform: translateY(-1px);
    }
    
    /* ===== RESPONSIVE BREAKPOINTS ===== */
    
    @@media (max-width: 1200px) {
        .tx-body { padding: 1rem; }
        .tx-stats-row { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .budget-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; }
        .header-right { gap: .75rem; }
    }
    
    @@media (max-width: 992px) {
        .sidebar { transform: translateX(-100%); }
        .sidebar.open { transform: translateX(0); }
        .sidebar-close-btn,
        .sidebar-toggle-btn { display: flex; }
        .main-content {
            margin-left: 0 !important;
            width: 100%;
        }
        .dashboard-header { padding: 0 1rem; }
        .header-greeting h2 { font-size: 1.1rem; }
        .tx-stats-row { grid-template-columns: repeat(2, 1fr); }
        .budget-grid { grid-template-columns: repeat(2, 1fr); }
    }
    
    @@media (max-width: 768px) {
        .tx-body { padding: .75rem; }
        .dashboard-header {
            flex-wrap: wrap;
            height: auto;
            min-height: 70px;
            padding: .75rem 1rem;
        }
        .header-left,
        .header-right { width: 100%; }
        .header-right { justify-content: flex-end; margin-top: 0.5rem; }
        .tx-stats-row {
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }
        .tx-stat { padding: 1rem; }
        .budget-grid { grid-template-columns: 1fr; gap: 1rem; }
        .budget-card { padding: 1rem; }
