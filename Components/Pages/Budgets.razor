@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("eval", @"
                console.log('Budgets: Blazor render complete');
                if (typeof setupBudgetsSidebar === 'function') {
                    setupBudgetsSidebar();
                    setTimeout(function() { loadBudgets(); }, 300);
                } else {
                    console.error('Budgets: setupBudgetsSidebar not found! Check if budgets.js is loaded.');
                }
            ");
        }
    }
