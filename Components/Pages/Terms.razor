                            </div>
                        </div>
                        <div class="liability-item">
                            <i class="bi bi-shield-slash"></i>
                            <div>
                                <h4>Data Loss</h4>
                                <p>Loss of data or inability to access your information</p>
                            </div>
                        </div>
                        <div class="liability-item">
                            <i class="bi bi-people"></i>
                            <div>
                                <h4>User Actions</h4>
                                <p>Actions or omissions of other users or third parties</p>
                            </div>
                        </div>
                    </div>

                    <div class="warning-box">
                        <i class="bi bi-gavel"></i>
                        <div>
                            <p><strong>Limitation:</strong> In no event shall our total liability exceed the amount you paid us in the 12 months preceding the claim, or $100, whichever is greater.</p>
                        </div>
                    </div>
                </div>

                <!-- Section 8 -->
