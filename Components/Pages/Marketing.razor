                        </div>
                        <p>For families and households</p>
                    </div>
                    <div class="pricing-features">
                        <div class="feature"><i class="bi bi-check-circle-fill"></i><span>Everything in Pro</span></div>
                        <div class="feature"><i class="bi bi-check-circle-fill"></i><span>Up to 5 family members</span></div>
                        <div class="feature"><i class="bi bi-check-circle-fill"></i><span>Shared budgets</span></div>
