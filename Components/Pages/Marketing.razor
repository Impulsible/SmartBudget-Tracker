@code {
    private bool _isLoggedIn = false;
    private string _firstName = "";
    private string _initials = "";
    private string _userEmail = "";
    private string _fullName = "";
    private HubConnection? _hubConnection;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Get auth state
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                _isLoggedIn = true;
                _userEmail = user.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "";
                _fullName = user.FindFirst("FullName")?.Value ?? _userEmail.Split('@')[0];
                _firstName = _fullName.Split(' ')[0];
                _initials = _firstName.Length >= 2 ? _firstName.Substring(0, 2).ToUpper() : _firstName.ToUpper();
                Console.WriteLine($"SmartBudget: User authenticated - {_fullName}");
            }
            else
            {
                Console.WriteLine("SmartBudget: User not authenticated");
            }

            // Initialize SignalR connection for real-time updates
            if (_isLoggedIn)
            {
                _hubConnection = new HubConnectionBuilder()
                    .WithUrl(Nav.ToAbsoluteUri("/budgetHub"))
                    .WithAutomaticReconnect()
                    .Build();

                _hubConnection.On("DashboardUpdated", async () =>
                {
                    // 🔥 FIX: Force reset counters on SignalR update
                    await InvokeAsync(() =>
                    {
                        Console.WriteLine("SmartBudget: Dashboard update received via SignalR");
                        JS.InvokeVoidAsync("resetAndInitializeCounters");
                    });
                });

                await _hubConnection.StartAsync();
                Console.WriteLine("SmartBudget: SignalR connected");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"SmartBudget: Error - {ex.Message}");
            _isLoggedIn = false;
        }
        await base.OnInitializedAsync();
    }

    // 🔥 FIX 1: Run JS EVERY TIME, not just firstRender
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("initializeMarketingPage");
        await JS.InvokeVoidAsync("resetAndInitializeCounters");
    }

    // 🔥 FIX 2: Force re-render on navigation
    protected override void OnParametersSet()
    {
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection != null)
        {
            await _hubConnection.DisposeAsync();
        }
    }
}