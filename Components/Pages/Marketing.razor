    <!-- ============================================
    FAQ SECTION
    ============================================ -->
    <section class="faq-pro">
        <div class="container">
            <div class="section-header">
                <span class="section-badge">FAQ</span>
                <h2 class="section-title-pro">Frequently asked questions</h2>
                <p class="section-subtitle">Got questions? We've got answers.</p>
            </div>
            <div class="faq-grid">
                <div class="faq-item">
                    <div class="faq-question">
                        <i class="bi bi-question-circle"></i>
                        <span>Is SmartBudget really free?</span>
                        <i class="bi bi-chevron-down"></i>
                    </div>
                    <div class="faq-answer">
                        <p>Yes! SmartBudget offers a free plan that includes up to 100 transactions per month, 5 budget categories, and basic reports. You can upgrade to Pro for unlimited features anytime.</p>
                    </div>
                </div>
                <div class="faq-item">
                    <div class="faq-question">
                        <i class="bi bi-question-circle"></i>
                        <span>Is my financial data secure?</span>
                        <i class="bi bi-chevron-down"></i>
                    </div>
                    <div class="faq-answer">
                        <p>Absolutely! We use bank-level encryption to protect your data. Your information is never shared with third parties, and we're fully compliant with data protection regulations.</p>
                    </div>
                </div>
                <div class="faq-item">
                    <div class="faq-question">
                        <i class="bi bi-question-circle"></i>
                        <span>Can I export my data?</span>
                        <i class="bi bi-chevron-down"></i>
                    </div>
                    <div class="faq-answer">
                        <p>Yes! Pro users can export their financial data to CSV format for tax purposes or external analysis. Free users can upgrade anytime to access this feature.</p>
                    </div>
                </div>
                <div class="faq-item">
                    <div class="faq-question">
                        <i class="bi bi-question-circle"></i>
                        <span>Can I cancel my subscription?</span>
                        <i class="bi bi-chevron-down"></i>
                    </div>
                    <div class="faq-answer">
                        <p>You can cancel your Pro subscription at any time. Your account will revert to the Free plan, and you'll keep all your data.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ============================================
    CTA SECTION
    ============================================ -->
