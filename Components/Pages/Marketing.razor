                    <span class="popular-badge">Most Popular</span>
                    <div class="pricing-header">
                        <h3>Pro</h3>
                        <div class="price">
                            <span class="currency">₦</span>
                            <span class="amount">2,500</span>
                            <span class="period">/month</span>
                        </div>
                        <p>For serious budgeters</p>
                    </div>
                    <div class="pricing-features">
                        <div class="feature"><i class="bi bi-check-circle-fill"></i><span>Unlimited transactions</span></div>
                        <div class="feature"><i class="bi bi-check-circle-fill"></i><span>Unlimited budget categories</span></div>
                        <div class="feature"><i class="bi bi-check-circle-fill"></i><span>Advanced analytics & reports</span></div>
                        <div class="feature"><i class="bi bi-check-circle-fill"></i><span>Export to CSV/Excel</span></div>
                        <div class="feature"><i class="bi bi-check-circle-fill"></i><span>Priority support</span></div>
                    </div>
                    <a href="/Account/Register" class="btn-pricing-primary">Start Free Trial</a>
                </div>
                <div class="pricing-card">
                    <div class="pricing-header">
                        <h3>Family</h3>
                        <div class="price">
                            <span class="currency">₦</span>
