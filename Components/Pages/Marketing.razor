                        <i class="bi bi-star-fill"></i>
                    </div>
                    <p>"Finally, a budgeting app that actually works. The interface is clean and intuitive. Highly recommended!"</p>
                    <div class="testimonial-author-pro">
                        <div class="author-avatar"><i class="bi bi-person-circle"></i></div>
                        <div>
                            <strong>Emeka O.</strong>
                            <span>Abuja, Nigeria</span>
                        </div>
                    </div>
                </div>
                <div class="testimonial-card-pro">
                    <div class="stars">
                        <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                    </div>
                    <p>"The savings goals feature keeps me motivated. I'm finally saving for my dream vacation!"</p>
                    <div class="testimonial-author-pro">
                        <div class="author-avatar"><i class="bi bi-person-circle"></i></div>
                        <div>
                            <strong>Folake A.</strong>
                            <span>Port Harcourt, Nigeria</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ============================================
    PRICING SECTION
    ============================================ -->
    <section id="pricing" class="pricing-pro">
        <div class="container">
            <div class="section-header">
                <span class="section-badge">Pricing</span>
                <h2 class="section-title-pro">Simple, transparent pricing</h2>
                <p class="section-subtitle">Choose the plan that works for you. Upgrade anytime.</p>
            </div>
            <div class="pricing-grid">
                <div class="pricing-card">
                    <div class="pricing-header">
                        <h3>Free</h3>
                        <div class="price">
                            <span class="currency">₦</span>
                            <span class="amount">0</span>
                            <span class="period">/month</span>
