@page "/contact"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.JSInterop
@attribute [AllowAnonymous]
@inherits BasePage
@implements IDisposable
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>SmartBudget - Contact Us</PageTitle>

<div class="contact-page">
    <!-- BREADCRUMB NAVIGATION -->
    <div class="breadcrumb-container">
        <div class="container">
            <nav aria-label="Breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a href="/"><i class="bi bi-house-door"></i> Home</a>
                    </li>
                    <li class="breadcrumb-item">
                        <i class="bi bi-chevron-right"></i>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">
                        Contact Us
                    </li>
                </ol>
            </nav>
        </div>
    </div>

    <!-- HERO SECTION -->
    <section class="contact-hero">
        <div class="container">
            <div class="contact-hero-content">
                <div class="contact-badge">📬 Get in Touch</div>
                <h1>We'd Love to <span class="gradient-text">Hear From You</span></h1>
                <p>Have questions, feedback, or need support? Reach out to us and we'll get back to you within 24 hours.</p>
            </div>
        </div>
    </section>

    <!-- CONTACT SECTION -->
    <section class="contact-section">
        <div class="container">
            <div class="contact-grid">
                <div class="contact-form-card">
                    <h2>Send Us a Message</h2>
                    <p>Fill in the form below and we'll respond as soon as possible.</p>
                    
                    <div id="contactSuccessMessage" class="alert alert-success" style="display:none;">
                        <div class="alert-icon"><i class="bi bi-check-circle-fill"></i></div>
                        <div class="alert-content">
                            <strong>Message Sent!</strong>
                            <span>Thank you for reaching out. We'll get back to you within 24 hours.</span>
                        </div>
                    </div>

                    <div id="contactErrorMessage" class="alert alert-error" style="display:none;">
                        <div class="alert-icon"><i class="bi bi-exclamation-triangle-fill"></i></div>
                        <div class="alert-content">
                            <strong>Error</strong>
                            <span id="contactErrorText"></span>
                        </div>
                    </div>

                    <form id="contactForm" onsubmit="return false;">
                        <div class="form-group">
                            <label class="form-label"><span class="label-icon"><i class="bi bi-person"></i></span>Your Name</label>
                            <input type="text" id="contactName" class="form-control" placeholder="John Doe" required />
                        </div>

                        <div class="form-group">
                            <label class="form-label"><span class="label-icon"><i class="bi bi-envelope"></i></span>Email Address</label>
                            <input type="email" id="contactEmail" class="form-control" placeholder="you@example.com" required />
                        </div>

                        <div class="form-group">
                            <label class="form-label"><span class="label-icon"><i class="bi bi-tag"></i></span>Subject</label>
                            <select id="contactSubject" class="form-control">
                                <option value="general">General Inquiry</option>
                                <option value="support">Support Request</option>
                                <option value="feedback">Feedback</option>
                                <option value="bug">Report a Bug</option>
                                <option value="feature">Feature Request</option>
                                <option value="partnership">Partnership</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label class="form-label"><span class="label-icon"><i class="bi bi-chat-dots"></i></span>Message</label>
                            <textarea id="contactMessage" class="form-control" rows="5" placeholder="Tell us how we can help you..." required></textarea>
                        </div>

                        <button type="button" class="btn-send" id="sendContactBtn" onclick="window.sendContactMessage()">
                            <span>Send Message</span>
                            <i class="bi bi-send"></i>
                        </button>
                    </form>
                </div>

                <div class="contact-info-card">
                    <h3>Contact Information</h3>
                    <p>Here are the best ways to reach us.</p>

                    <div class="contact-info-items">
                        <div class="contact-info-item">
                            <div class="contact-info-icon"><i class="bi bi-envelope"></i></div>
                            <div>
                                <strong>Email</strong>
                                <span>support@smartbudget.com</span>
                            </div>
                        </div>

                        <div class="contact-info-item">
                            <div class="contact-info-icon"><i class="bi bi-telephone"></i></div>
                            <div>
                                <strong>Phone</strong>
                                <span>+234 800 SMARTBUDGET</span>
                            </div>
                        </div>

                        <div class="contact-info-item">
                            <div class="contact-info-icon"><i class="bi bi-geo-alt"></i></div>
                            <div>
                                <strong>Location</strong>
                                <span>Lagos, Nigeria</span>
                            </div>
                        </div>

                        <div class="contact-info-item">
                            <div class="contact-info-icon"><i class="bi bi-clock"></i></div>
                            <div>
                                <strong>Support Hours</strong>
                                <span>Mon - Fri, 9:00 AM - 6:00 PM WAT</span>
                            </div>
                        </div>
                    </div>

                    <div class="contact-social">
                        <h4>Follow Us</h4>
                        <div class="social-links">
                            <a href="#" aria-label="Twitter"><i class="bi bi-twitter-x"></i></a>
                            <a href="#" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
                            <a href="#" aria-label="GitHub"><i class="bi bi-github"></i></a>
                            <a href="#" aria-label="YouTube"><i class="bi bi-youtube"></i></a>
                            <a href="#" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- FAQ SECTION -->
    <section class="contact-faq">
        <div class="container">
            <div class="section-header">
                <span class="section-badge">FAQ</span>
                <h2 class="section-title-pro">Frequently Asked Questions</h2>
                <p class="section-subtitle">Find quick answers to common questions.</p>
            </div>
            <div class="faq-grid">
                <div class="faq-item">
                    <div class="faq-question"><i class="bi bi-question-circle"></i><span>How do I reset my password?</span><i class="bi bi-chevron-down"></i></div>
                    <div class="faq-answer"><p>Go to the <a href="/Account/Login">Login page</a> and click on "Forgot Password". Enter your email address and we'll send you a reset link.</p></div>
                </div>
                <div class="faq-item">
                    <div class="faq-question"><i class="bi bi-question-circle"></i><span>Is my data secure?</span><i class="bi bi-chevron-down"></i></div>
                    <div class="faq-answer"><p>Absolutely! We use bank-level encryption to protect your data. Your information is never shared with third parties.</p></div>
                </div>
                <div class="faq-item">
                    <div class="faq-question"><i class="bi bi-question-circle"></i><span>How do I export my data?</span><i class="bi bi-chevron-down"></i></div>
                    <div class="faq-answer"><p>Pro users can export their data to CSV format from the <a href="/export">Export page</a>. Free users can upgrade anytime.</p></div>
                </div>
                <div class="faq-item">
                    <div class="faq-question"><i class="bi bi-question-circle"></i><span>Can I use SmartBudget on mobile?</span><i class="bi bi-chevron-down"></i></div>
                    <div class="faq-answer"><p>Yes! SmartBudget is fully responsive and works perfectly on all devices - desktop, tablet, and mobile.</p></div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA SECTION -->
    <section class="cta-section">
        <div class="container">
            <div class="cta-content">
                <h2>Ready to take control of your finances?</h2>
                <p>Join thousands of Nigerians who trust SmartBudget with their money.</p>
                <a href="/Account/Register" class="btn-get-started">Get Started Free →</a>
            </div>
        </div>
    </section>

    <!-- ============================================
    FOOTER
    ============================================ -->
    <footer class="contact-footer">
        <div class="container">
            <div class="contact-footer-content">
                <p>&copy; @DateTime.Now.Year SmartBudget. All rights reserved.</p>
                <div class="contact-footer-links">
                    <a href="/">Home</a>
                    <a href="/about">About</a>
                    <a href="/blog">Blog</a>
                    <a href="/careers">Careers</a>
                    <a href="/contact">Contact</a>
                    <a href="/privacy">Privacy</a>
                    <a href="/terms">Terms</a>
                    <a href="/cookies">Cookies</a>
                    <a href="/security">Security</a>
                </div>
            </div>
        </div>
    </footer>
</div>

<style>
    .contact-page {
        background: #0B1120;
        min-height: 100vh;
        padding-top: 80px;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }

    /* ============================================
    BREADCRUMB NAVIGATION - NO LINE
    ============================================ */
    .container {
        width: 100%;
        max-width: 1280px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    .breadcrumb-container {
        padding: 0.75rem 0;
        margin-top: 0;
        background: transparent;
    }

    .breadcrumb {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        list-style: none;
        padding: 0;
        margin: 0;
        flex-wrap: wrap;
    }

    .breadcrumb-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.85rem;
        color: #94A3B8;
    }

    .breadcrumb-item a {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        color: #94A3B8;
        text-decoration: none;
        transition: all 0.2s ease;
        padding: 0.25rem 0.5rem;
        border-radius: 6px;
    }

    .breadcrumb-item a:hover {
        color: #10B981;
        background: rgba(16, 185, 129, 0.08);
    }

    .breadcrumb-item a i {
        font-size: 0.9rem;
    }

    .breadcrumb-item i.bi-chevron-right {
        color: #64748B;
        font-size: 0.65rem;
    }

    .breadcrumb-item.active {
        color: #F1F5F9;
        font-weight: 500;
        padding: 0.25rem 0.5rem;
        background: rgba(16, 185, 129, 0.1);
        border-radius: 6px;
        border: 1px solid rgba(16, 185, 129, 0.1);
    }

    /* ============================================
    HERO SECTION
    ============================================ */
    .contact-hero {
        padding: 2rem 0 2rem;
        background: linear-gradient(135deg, #0B1120 0%, #111827 50%, #1A2332 100%);
        text-align: center;
    }

    .contact-hero-content {
        max-width: 700px;
        margin: 0 auto;
    }

    .contact-badge {
        display: inline-block;
        background: rgba(16, 185, 129, 0.12);
        color: #10B981;
        padding: 0.4rem 1.2rem;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
        margin-bottom: 1rem;
        border: 1px solid rgba(16, 185, 129, 0.15);
    }

    .contact-hero h1 {
        font-size: clamp(2rem, 4vw, 2.8rem);
        font-weight: 700;
        color: #F1F5F9;
        margin-bottom: 0.75rem;
        line-height: 1.2;
    }

    .contact-hero .gradient-text {
        background: linear-gradient(135deg, #10B981 0%, #34D399 100%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }

    .contact-hero p {
        font-size: 1.0625rem;
        color: #94A3B8;
        max-width: 550px;
        margin: 0 auto;
        line-height: 1.6;
    }

    /* ============================================
    CONTACT SECTION
    ============================================ */
    .contact-section {
        padding: 3rem 0;
        background: #0B1120;
    }

    .contact-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
        max-width: 1100px;
        margin: 0 auto;
    }

    .contact-form-card {
        background: #1E293B;
        border-radius: 20px;
        padding: 2rem;
        border: 1px solid rgba(148, 163, 184, 0.08);
    }

    .contact-form-card h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #F1F5F9;
        margin-bottom: 0.5rem;
    }

    .contact-form-card > p {
        color: #94A3B8;
        font-size: 0.9375rem;
        margin-bottom: 1.5rem;
    }

    .contact-form-card .form-group {
        margin-bottom: 1.25rem;
    }

    .contact-form-card .form-label {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.8125rem;
        font-weight: 600;
        color: #CBD5E1;
        margin-bottom: 0.5rem;
    }

    .contact-form-card .label-icon {
        color: #10B981;
        font-size: 1rem;
    }

    .contact-form-card .form-control {
        width: 100%;
        padding: 0.75rem 1rem;
        background: #0F172A;
        border: 1px solid rgba(148, 163, 184, 0.15);
        border-radius: 10px;
        color: #F1F5F9;
        font-size: 0.9375rem;
        outline: none;
        font-family: 'Inter', sans-serif;
        transition: all 0.2s ease;
    }

    .contact-form-card .form-control:focus {
        border-color: #10B981;
        box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
    }

    .contact-form-card .form-control::placeholder {
        color: #64748B;
    }

    .contact-form-card textarea.form-control {
        resize: vertical;
        min-height: 120px;
    }

    .btn-send {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 2rem;
        background: linear-gradient(135deg, #10B981 0%, #059669 100%);
        color: white;
        border: none;
        border-radius: 12px;
        font-size: 0.9375rem;
        font-weight: 600;
        cursor: pointer;
        font-family: 'Inter', sans-serif;
        transition: all 0.3s ease;
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.25);
        width: 100%;
        justify-content: center;
    }

    .btn-send:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(16, 185, 129, 0.35);
    }

    .btn-send:disabled {
        opacity: 0.7;
        cursor: not-allowed;
    }

    .btn-send .spinner-sm {
        width: 18px;
        height: 18px;
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 0.6s linear infinite;
        display: inline-block;
    }

    .alert {
        display: flex;
        gap: 1rem;
        padding: 1rem 1.25rem;
        border-radius: 12px;
        margin-bottom: 1.5rem;
        align-items: flex-start;
    }

    .alert-icon {
        font-size: 1.25rem;
        flex-shrink: 0;
        margin-top: 2px;
    }

    .alert-content {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .alert-content strong {
        font-size: 0.875rem;
        font-weight: 600;
    }

    .alert-content span {
        font-size: 0.8125rem;
        line-height: 1.5;
    }

    .alert-success {
        background: rgba(16, 185, 129, 0.1);
        border: 1px solid rgba(16, 185, 129, 0.2);
        color: #6EE7B7;
    }

    .alert-success strong {
        color: #10B981;
    }

    .alert-error {
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.2);
        color: #FCA5A5;
    }

    .alert-error strong {
        color: #EF4444;
    }

    .contact-info-card {
        background: #1E293B;
        border-radius: 20px;
        padding: 2rem;
        border: 1px solid rgba(148, 163, 184, 0.08);
    }

    .contact-info-card h3 {
        font-size: 1.25rem;
        font-weight: 700;
        color: #F1F5F9;
        margin-bottom: 0.5rem;
    }

    .contact-info-card > p {
        color: #94A3B8;
        font-size: 0.875rem;
        margin-bottom: 1.5rem;
    }

    .contact-info-items {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .contact-info-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.75rem;
        background: #0F172A;
        border-radius: 12px;
        border: 1px solid rgba(148, 163, 184, 0.08);
        transition: all 0.2s ease;
    }

    .contact-info-item:hover {
        border-color: rgba(16, 185, 129, 0.2);
        background: #1A2332;
    }

    .contact-info-icon {
        width: 44px;
        height: 44px;
        background: rgba(16, 185, 129, 0.1);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        color: #10B981;
        font-size: 1.125rem;
    }

    .contact-info-item strong {
        display: block;
        font-size: 0.75rem;
        font-weight: 600;
        color: #64748B;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .contact-info-item span {
        font-size: 0.875rem;
        color: #F1F5F9;
    }

    .contact-social h4 {
        font-size: 0.875rem;
        font-weight: 600;
        color: #94A3B8;
        margin-bottom: 0.75rem;
    }

    .social-links {
        display: flex;
        gap: 0.75rem;
    }

    .social-links a {
        width: 42px;
        height: 42px;
        background: #0F172A;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #94A3B8;
        transition: all 0.3s ease;
        border: 1px solid rgba(148, 163, 184, 0.08);
        text-decoration: none;
    }

    .social-links a:hover {
        background: #10B981;
        color: white;
        border-color: #10B981;
        transform: translateY(-3px);
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
    }

    .contact-faq {
        padding: 3rem 0;
        background: #111827;
        border-top: 1px solid rgba(148, 163, 184, 0.06);
        border-bottom: 1px solid rgba(148, 163, 184, 0.06);
    }

    .contact-faq .section-header {
        text-align: center;
        margin-bottom: 2.5rem;
    }

    .contact-faq .section-badge {
        display: inline-block;
        background: rgba(16, 185, 129, 0.12);
        color: #10B981;
        padding: 0.3rem 1rem;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        margin-bottom: 0.75rem;
        border: 1px solid rgba(16, 185, 129, 0.15);
    }

    .contact-faq .section-title-pro {
        font-size: clamp(1.8rem, 3vw, 2.5rem);
        font-weight: 700;
        color: #F1F5F9;
        margin-bottom: 0.5rem;
        line-height: 1.2;
    }

    .contact-faq .section-subtitle {
        font-size: 0.9375rem;
        color: #94A3B8;
        max-width: 550px;
        margin: 0 auto;
        line-height: 1.6;
    }

    .contact-faq .faq-grid {
        max-width: 800px;
        margin: 0 auto;
    }

    .contact-faq .faq-item {
        background: #1E293B;
        border-radius: 12px;
        margin-bottom: 0.75rem;
        border: 1px solid rgba(148, 163, 184, 0.1);
        overflow: hidden;
        transition: all 0.3s ease;
    }

    .contact-faq .faq-item:hover {
        border-color: rgba(148, 163, 184, 0.2);
    }

    .contact-faq .faq-question {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.85rem 1.25rem;
        cursor: pointer;
        transition: background 0.2s ease;
    }

    .contact-faq .faq-question:hover {
        background: #253349;
    }

    .contact-faq .faq-question i:first-child {
        color: #10B981;
        font-size: 0.9rem;
    }

    .contact-faq .faq-question span {
        flex: 1;
        font-weight: 600;
        color: #F1F5F9;
        font-size: 0.875rem;
    }

    .contact-faq .faq-question i:last-child {
        color: #64748B;
        transition: transform 0.3s ease;
        font-size: 0.8rem;
    }

    .contact-faq .faq-item.open .faq-question i:last-child {
        transform: rotate(180deg);
    }

    .contact-faq .faq-answer {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease, padding 0.3s ease;
        padding: 0 1.25rem;
    }

    .contact-faq .faq-item.open .faq-answer {
        max-height: 500px;
        padding: 0 1.25rem 1rem;
    }

    .contact-faq .faq-answer p {
        color: #94A3B8;
        line-height: 1.6;
        font-size: 0.85rem;
        margin: 0;
    }

    .contact-faq .faq-answer a {
        color: #10B981;
        text-decoration: none;
        font-weight: 500;
    }

    .contact-faq .faq-answer a:hover {
        color: #34D399;
        text-decoration: underline;
    }

    .cta-section {
        padding: 3rem 0;
        background: #0B1120;
        text-align: center;
    }

    .cta-content {
        max-width: 600px;
        margin: 0 auto;
    }

    .cta-content h2 {
        font-size: clamp(1.5rem, 3vw, 2.2rem);
        font-weight: 700;
        color: #F1F5F9;
        margin-bottom: 0.75rem;
    }

    .cta-content p {
        color: #94A3B8;
        font-size: 0.9375rem;
        margin-bottom: 1.5rem;
    }

    .btn-get-started {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.9rem 2.5rem;
        background: linear-gradient(135deg, #10B981 0%, #059669 100%);
        color: white;
        text-decoration: none;
        border-radius: 12px;
        font-size: 1rem;
        font-weight: 600;
        font-family: 'Inter', sans-serif;
        transition: all 0.3s ease;
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.25);
        border: none;
        cursor: pointer;
        position: relative;
        overflow: hidden;
    }

    .btn-get-started::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
        transition: left 0.5s ease;
    }

    .btn-get-started:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 24px rgba(16, 185, 129, 0.35);
        color: white;
    }

    .btn-get-started:hover::before {
        left: 100%;
    }

    .btn-get-started:active {
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);
    }

    /* ============================================
    FOOTER
    ============================================ */
    .contact-footer {
        padding: 1.5rem 0;
        background: #0B1120;
