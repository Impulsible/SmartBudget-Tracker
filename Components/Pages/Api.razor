<script>
    // ============================================
    // API PAGE FUNCTIONS
    // ============================================

    window.copyBaseUrl = function() {
        var urlElement = document.getElementById('baseUrl');
        var url = urlElement.textContent;
        
        navigator.clipboard.writeText(url).then(function() {
            var btn = document.querySelector('.btn-copy');
            var originalText = btn.innerHTML;
            btn.innerHTML = '<i class="bi bi-check"></i> Copied!';
            btn.style.background = 'rgba(16, 185, 129, 0.2)';
            
            setTimeout(function() {
                btn.innerHTML = originalText;
                btn.style.background = '';
            }, 2000);
        });
    };

    window.tryApi = function() {
        var method = document.getElementById('tryMethod').value;
        var endpoint = document.getElementById('tryEndpoint').value;
        var responseDiv = document.getElementById('tryResponse');
        
        responseDiv.innerHTML = '<p style="color:#F59E0B;">⏳ Sending request...</p>';
        
        var baseUrl = 'https://smartbudget-tracker.onrender.com';
        var url = baseUrl + endpoint;
        
        fetch(url, {
            method: method,
            headers: {
                'Content-Type': 'application/json',
                'Accept': 'application/json'
            }
        })
        .then(function(response) {
            var status = response.status;
            var statusText = response.statusText;
            
            return response.text().then(function(text) {
                var result;
                try {
                    result = JSON.parse(text);
                } catch (e) {
                    result = text;
                }
                
                var responseHtml = '<div style="margin-bottom:.5rem;">';
                responseHtml += '<span style="color:' + (status >= 200 && status < 300 ? '#34D399' : '#EF4444') + ';font-weight:600;">Status: ' + status + ' ' + statusText + '</span>';
                responseHtml += '</div>';
                
                if (typeof result === 'object') {
                    responseHtml += '<pre><code>' + JSON.stringify(result, null, 2) + '</code></pre>';
                } else {
                    responseHtml += '<pre><code>' + result + '</code></pre>';
                }
                
                responseDiv.innerHTML = responseHtml;
            });
        })
        .catch(function(error) {
            responseDiv.innerHTML = '<p style="color:#EF4444;">❌ Error: ' + error.message + '</p>';
        });
    };

    // Auto-try on load with GET /api
    document.addEventListener('DOMContentLoaded', function() {
        setTimeout(function() {
            var endpoint = document.getElementById('tryEndpoint');
            if (endpoint) {
                endpoint.value = '/api';
            }
        }, 500);
    });
</script>

