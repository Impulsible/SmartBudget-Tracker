@page "/reports"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inherits BasePage
@inject IJSRuntime JS

<PageTitle>SmartBudget - Reports</PageTitle>

<div class="tx-layout">
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <a href="/dashboard" class="sidebar-logo">
                <div class="sidebar-logo-icon"><i class="bi bi-piggy-bank"></i></div>
                <span class="sidebar-logo-text">Smart<span>Budget</span></span>
            </a>
            <button class="sidebar-close-btn" id="sidebarCloseBtn"><i class="bi bi-x-lg"></i></button>
        </div>
        <nav class="sidebar-nav">
            <div class="nav-section">
                <span class="nav-section-title">Main Menu</span>
                <a href="/dashboard" class="nav-item"><i class="bi bi-speedometer2"></i><span>Dashboard</span></a>
                <a href="/transactions" class="nav-item"><i class="bi bi-arrow-left-right"></i><span>Transactions</span></a>
                <a href="/budgets" class="nav-item"><i class="bi bi-pie-chart"></i><span>Budgets</span></a>
                <a href="/goals" class="nav-item"><i class="bi bi-flag"></i><span>Goals</span></a>
            </div>
            <div class="nav-section">
                <span class="nav-section-title">Tools</span>
                <a href="/reports" class="nav-item active"><i class="bi bi-file-earmark-bar-graph"></i><span>Reports</span></a>
                <a href="/export" class="nav-item"><i class="bi bi-download"></i><span>Export Data</span></a>
                <a href="/settings" class="nav-item"><i class="bi bi-gear"></i><span>Settings</span></a>
            </div>
        </nav>
        <div class="sidebar-footer">
            <div class="sidebar-user-info">
                <span class="sidebar-user-name">SmartBudget</span>
                <span class="sidebar-version">v1.0</span>
            </div>
            <a href="/Account/Logout" class="sidebar-logout" title="Logout"><i class="bi bi-box-arrow-right"></i></a>
        </div>
    </aside>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- Main Content -->
    <main class="main-content">
        <header class="dashboard-header">
            <div class="header-left">
                <button class="sidebar-toggle-btn" id="sidebarToggleBtn"><i class="bi bi-list"></i></button>
                <div class="header-greeting">
                    <h2>Financial Reports</h2>
                    <p>Analyze your spending and income patterns</p>
                </div>
            </div>
            <div class="header-right">
                <div class="header-date"><i class="bi bi-calendar3"></i><span id="reportDate">@DateTime.Now.ToString("MMMM yyyy")</span></div>
            </div>
        </header>

        <div class="tx-body">
            <!-- Period Selector -->
            <div class="report-periods">
                <button class="report-period active" data-period="month" onclick="changeReportPeriod('month', this)">This Month</button>
                <button class="report-period" data-period="quarter" onclick="changeReportPeriod('quarter', this)">Last 3 Months</button>
                <button class="report-period" data-period="year" onclick="changeReportPeriod('year', this)">This Year</button>
                <button class="report-period" data-period="all" onclick="changeReportPeriod('all', this)">All Time</button>
            </div>

            <!-- Summary Stats -->
            <div class="tx-stats-row" id="reportStatsRow">
                <div class="tx-stat income">
                    <span class="tx-stat-label">Total Income</span>
                    <span class="tx-stat-value" id="rptIncome">₦0</span>
                </div>
                <div class="tx-stat expense">
                    <span class="tx-stat-label">Total Expenses</span>
                    <span class="tx-stat-value" id="rptExpenses">₦0</span>
                </div>
                <div class="tx-stat balance">
                    <span class="tx-stat-label">Net Savings</span>
                    <span class="tx-stat-value" id="rptSavings">₦0</span>
                </div>
                <div class="tx-stat count">
                    <span class="tx-stat-label">Transactions</span>
                    <span class="tx-stat-value" id="rptCount">0</span>
                </div>
            </div>

            <!-- Charts Row -->
            <div class="charts-row">
                <div class="chart-card">
                    <div class="chart-card-header"><h3>Income vs Expenses Trend</h3></div>
                    <div class="chart-container" style="height:350px;"><canvas id="reportTrendChart"></canvas></div>
                </div>
                <div class="chart-card">
                    <div class="chart-card-header"><h3>Expense Breakdown</h3></div>
                    <div class="chart-container" style="height:350px;"><canvas id="reportExpenseChart"></canvas></div>
                </div>
            </div>

            <!-- Second Charts Row -->
            <div class="charts-row">
                <div class="chart-card">
                    <div class="chart-card-header"><h3>Savings Rate</h3></div>
                    <div class="chart-container" style="height:300px;"><canvas id="reportSavingsChart"></canvas></div>
                </div>
                <div class="chart-card">
                    <div class="chart-card-header"><h3>Top Spending Categories</h3></div>
                    <div class="report-top-categories" id="topCategories"></div>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <footer class="tx-footer">
            <div class="tx-footer-content">
                <p>&copy; @DateTime.Now.Year SmartBudget. All rights reserved.</p>
                <div class="tx-footer-links">
                    <a href="/privacy">Privacy</a>
                    <a href="/terms">Terms</a>
                    <a href="/contact">Contact</a>
                </div>
            </div>
        </footer>
    </main>
</div>

<style>
    :root {
        --sidebar-width: 260px;
        --header-height: 70px;
        --brand: #10B981;
        --brand-dark: #059669;
        --bg-dashboard: #0F172A;
        --bg-sidebar: #0B1120;
        --bg-card: #1E293B;
        --text-primary: #F1F5F9;
        --text-secondary: #94A3B8;
        --text-muted: #64748B;
        --border-color: rgba(148, 163, 184, 0.1);
        --income-color: #10B981;
        --expense-color: #EF4444;
    }
    
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { width: 100%; overflow-x: hidden; }
    
    .tx-layout {
        display: flex;
        min-height: 100vh;
        background: var(--bg-dashboard);
        font-family: 'Inter', sans-serif;
        color: var(--text-primary);
    }
    
    /* ===== SIDEBAR ===== */
    .sidebar {
        position: fixed;
        top: 0;
        left: 0;
        bottom: 0;
        width: var(--sidebar-width);
        background: var(--bg-sidebar);
        border-right: 1px solid var(--border-color);
        display: flex;
        flex-direction: column;
        z-index: 100;
        transition: transform 0.3s;
        overflow-y: auto;
    }
    
    .sidebar-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--border-color);
    }
    
    .sidebar-logo {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        text-decoration: none;
    }
    
    .sidebar-logo-icon {
        width: 38px;
        height: 38px;
        background: linear-gradient(135deg, var(--brand), var(--brand-dark));
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .sidebar-logo-icon i { font-size: 20px; color: white; }
    
    .sidebar-logo-text {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--text-primary);
    }
    
    .sidebar-logo-text span { color: var(--brand); }
    
    .sidebar-close-btn {
        display: none;
        background: none;
        border: none;
        color: var(--text-secondary);
        font-size: 1.5rem;
        cursor: pointer;
        padding: 0.25rem;
    }
    
    .sidebar-close-btn:hover { color: var(--text-primary); }
    
    .sidebar-nav { flex: 1; padding: 1.25rem 0.75rem; overflow-y: auto; }
    
    .nav-section { margin-bottom: 1.5rem; }
    
    .nav-section-title {
        display: block;
        font-size: 0.6875rem;
        font-weight: 600;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 0 1rem;
        margin-bottom: 0.5rem;
    }
    
    .nav-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.625rem 1rem;
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        border-radius: 8px;
        transition: all 0.15s;
        margin-bottom: 0.125rem;
    }
    
    .nav-item:hover { background: rgba(255, 255, 255, 0.04); color: var(--text-primary); }
    
    .nav-item.active {
        background: rgba(16, 185, 129, 0.1);
        color: var(--brand);
        font-weight: 600;
    }
    
    .nav-item i { font-size: 1.125rem; width: 22px; text-align: center; }
    
    .sidebar-footer {
        padding: 1rem 1.25rem;
        border-top: 1px solid var(--border-color);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
    }
    
    .sidebar-user-info { display: flex; flex-direction: column; }
    
    .sidebar-user-name {
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--text-primary);
    }
    
    .sidebar-version { font-size: 0.6875rem; color: var(--text-muted); }
    
    .sidebar-logout {
        color: var(--text-muted);
        font-size: 1.125rem;
        padding: 0.5rem;
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.15s;
    }
    
    .sidebar-logout:hover { color: var(--expense-color); background: rgba(239, 68, 68, 0.1); }
    
    .sidebar-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.6);
        z-index: 99;
    }
    
    .sidebar-overlay.open { display: block; }
    
    /* ===== MAIN CONTENT ===== */
    .main-content {
        flex: 1;
        margin-left: var(--sidebar-width);
        width: calc(100% - var(--sidebar-width));
        min-width: 0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }
    
    /* ===== HEADER ===== */
    .dashboard-header {
        position: sticky;
        top: 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 2rem;
        height: var(--header-height);
        background: rgba(15, 23, 42, 0.9);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border-color);
        z-index: 50;
    }
    
    .header-left { display: flex; align-items: center; gap: 1rem; }
    
    .sidebar-toggle-btn {
        display: none;
        background: none;
        border: none;
        color: var(--text-secondary);
        font-size: 1.5rem;
        cursor: pointer;
        padding: 0.25rem;
    }
    
    .sidebar-toggle-btn:hover { color: var(--text-primary); }
    
    .header-greeting h2 { font-size: 1.25rem; font-weight: 700; color: var(--text-primary); }
    
    .header-greeting p {
        font-size: 0.8125rem;
        color: var(--text-secondary);
        margin-top: 0.125rem;
    }
    
    .header-right { display: flex; align-items: center; gap: 1rem; }
    
    .header-date {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--text-secondary);
        font-size: 0.8125rem;
    }
    
    /* ===== BODY ===== */
    .tx-body { flex: 1; padding: 1.5rem 2rem; }
    
    /* ===== STATS ===== */
    .tx-stats-row {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1.25rem;
        margin-bottom: 1.5rem;
    }
    
    .tx-stat {
        background: var(--bg-card);
        border-radius: 16px;
        padding: 1.25rem;
        border: 1px solid var(--border-color);
        text-align: center;
        transition: all 0.2s;
    }
    
    .tx-stat:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
    }
    
    .tx-stat-label {
        display: block;
        font-size: 0.75rem;
        color: var(--text-muted);
        text-transform: uppercase;
        margin-bottom: 0.5rem;
        letter-spacing: 0.05em;
    }
    
    .tx-stat-value {
        font-size: clamp(1.25rem, 3vw, 1.5rem);
        font-weight: 700;
        line-height: 1.2;
        overflow-wrap: anywhere;
    }
    
    .tx-stat.income .tx-stat-value { color: var(--income-color); }
    .tx-stat.expense .tx-stat-value { color: var(--expense-color); }
    .tx-stat.balance .tx-stat-value { color: #3B82F6; }
    .tx-stat.count .tx-stat-value { color: #F1F5F9; }
    
    /* ===== REPORT PERIODS ===== */
    .report-periods {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
    }
    
    .report-period {
        padding: 0.5rem 1.25rem;
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        color: var(--text-secondary);
        font-size: 0.8125rem;
        cursor: pointer;
        font-family: 'Inter', sans-serif;
        transition: all 0.15s;
    }
    
    .report-period.active {
        background: var(--brand);
        border-color: var(--brand);
        color: white;
    }
    
    .report-period:hover:not(.active) { border-color: var(--text-muted); }
    
    /* ===== CHARTS ===== */
    .charts-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.25rem;
        margin-bottom: 1.5rem;
    }
    
    .chart-card {
        background: var(--bg-card);
        border-radius: 16px;
        padding: 1.25rem;
        border: 1px solid var(--border-color);
    }
    
    .chart-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1rem;
        flex-wrap: wrap;
        gap: 0.5rem;
    }
    
    .chart-card-header h3 {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-primary);
    }
    
    .chart-container {
        width: 100%;
        position: relative;
        min-height: 280px;
    }
    
    .chart-container canvas { width: 100% !important; height: 100% !important; }
    
    /* ===== TOP CATEGORIES ===== */
    .report-top-categories {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }
    
    .top-cat-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem;
        background: rgba(255, 255, 255, 0.02);
        border-radius: 10px;
        flex-wrap: wrap;
    }
    
    .top-cat-rank {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        font-weight: 700;
        color: white;
        flex-shrink: 0;
    }
    
    .top-cat-info { flex: 1; min-width: 100px; }
    
    .top-cat-name {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--text-primary);
        word-break: break-word;
    }
    
    .top-cat-amount { font-size: 0.75rem; color: var(--text-muted); }
    
    .top-cat-bar {
        width: 80px;
        height: 6px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 3px;
        overflow: hidden;
        flex-shrink: 0;
    }
    
    .top-cat-fill { height: 100%; border-radius: 3px; transition: width 0.5s ease; }
    
    .top-cat-percent {
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--text-secondary);
        width: 50px;
        text-align: right;
        flex-shrink: 0;
    }
    
    /* ===== FOOTER ===== */
    .tx-footer {
        background: var(--bg-sidebar);
        border-top: 1px solid var(--border-color);
        padding: 1.5rem 2rem;
        margin-top: auto;
    }
    
    .tx-footer-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }
    
    .tx-footer-content p { color: var(--text-muted); font-size: 0.8125rem; }
    
    .tx-footer-links { display: flex; gap: 1.5rem; }
    
    .tx-footer-links a {
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.8125rem;
        transition: color 0.15s;
    }
    
    .tx-footer-links a:hover { color: var(--brand); }
    
    /* ===== RESPONSIVE BREAKPOINTS ===== */
    
    @@media (max-width: 1200px) {
        .tx-body { padding: 1rem; }
        .tx-stats-row { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .charts-row { grid-template-columns: 1fr; }
        .chart-container { min-height: 280px; }
    }
    
    @@media (max-width: 992px) {
        .sidebar { transform: translateX(-100%); }
        .sidebar.open { transform: translateX(0); }
        .sidebar-close-btn,
        .sidebar-toggle-btn { display: flex; }
        .main-content {
            margin-left: 0 !important;
            width: 100%;
        }
        .dashboard-header { padding: 0 1rem; }
        .header-greeting h2 { font-size: 1.1rem; }
        .tx-stats-row { grid-template-columns: repeat(2, 1fr); }
    }
    
    @@media (max-width: 768px) {
        .tx-body { padding: .75rem; }
        .dashboard-header {
            flex-wrap: wrap;
            height: auto;
            min-height: 70px;
            padding: .75rem 1rem;
        }
        .header-left,
        .header-right { width: 100%; }
        .header-right { justify-content: flex-end; margin-top: 0.5rem; }
        .tx-stats-row {
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }
        .tx-stat { padding: 1rem; }
        .report-periods {
            overflow-x: auto;
            flex-wrap: nowrap;
            -webkit-overflow-scrolling: touch;
            padding-bottom: 0.5rem;
        }
        .report-period { white-space: nowrap; }
        .chart-container { min-height: 250px; }
        .chart-card-header h3 { font-size: 0.875rem; }
        .top-cat-item { gap: 0.5rem; }
        .top-cat-bar { width: 60px; }
        .top-cat-percent { width: 45px; font-size: 0.7rem; }
        .header-greeting h2 { font-size: 1rem; }
        .header-greeting p { font-size: .75rem; }
        .tx-footer-content {
            flex-direction: column;
            text-align: center;
        }
    }
    
    @@media (max-width: 480px) {
        .dashboard-header { padding: .75rem; }
        .header-greeting h2 { font-size: .95rem; }
        .tx-stats-row {
            grid-template-columns: 1fr;
            gap: 0.75rem;
        }
        .tx-stat { border-radius: 14px; padding: 1rem; }
        .tx-stat-value { font-size: 1.25rem; }
        .charts-row { grid-template-columns: 1fr; }
        .chart-container { min-height: 220px; }
        .report-period { padding: 0.375rem 0.875rem; font-size: 0.75rem; }
        .top-cat-item { flex-wrap: wrap; }
        .top-cat-info { min-width: 120px; }
        .top-cat-bar {
            width: 100%;
            order: 3;
            margin-top: 0.5rem;
        }
        .top-cat-percent { text-align: left; width: auto; }
        .chart-card { padding: 1rem; }
    }
</style>

<script src="/js/reports.js"></script>

@code {
    // ✅ Set page name for BasePage initialization
    protected override async Task OnInitializedAsync()
    {
        PageName = "reports";
        await base.OnInitializedAsync();
    }

    // ✅ Call JavaScript initialization
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initReportsPage");
        }
    }
}