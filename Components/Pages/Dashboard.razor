    .btn-save{padding:0.625rem 1.5rem;background:var(--brand);border:none;border-radius:8px;color:white;cursor:pointer;font-size:0.875rem;font-weight:600;font-family:'Inter',sans-serif}.btn-save:hover{background:var(--brand-dark)}
    
    /* ===== RESPONSIVE BREAKPOINTS ===== */
    @@media (max-width: 1200px){.dashboard-body{padding:1rem}.stats-row{grid-template-columns:repeat(2,minmax(0,1fr))}.charts-row{grid-template-columns:1fr}.header-right{gap:.75rem}}
    @@media (max-width: 992px){.sidebar{transform:translateX(-100%)}.sidebar.open{transform:translateX(0)}.sidebar-close-btn,.sidebar-toggle-btn{display:flex}.main-content{margin-left:0!important;width:100%}.dashboard-header{padding:0 1rem}.header-date{display:none}.header-greeting h2{font-size:1.1rem}.stats-row{grid-template-columns:repeat(2,1fr)}.chart-container{height:280px}}
    @@media (max-width: 768px){.dashboard-body{padding:.75rem}.dashboard-header{flex-wrap:wrap;height:auto;min-height:70px;padding:.75rem 1rem}.header-left,.header-right{width:100%}.header-right{justify-content:flex-end}.stats-row{grid-template-columns:1fr;gap:1rem}.stat-card{padding:1rem}.stat-card-body .stat-value{font-size:clamp(1.6rem,5vw,2rem);word-break:break-word}.charts-row{grid-template-columns:1fr}.chart-card-header{flex-direction:column;align-items:flex-start;gap:.75rem}.chart-container{height:250px}.transactions-header{flex-direction:column;align-items:flex-start}.transactions-actions{width:100%;justify-content:space-between}.btn-add-transaction,.btn-clear-all,.btn-view-all{width:100%;justify-content:center}.transactions-table{min-width:700px}.modal-content{max-width:100%;margin:0}}
    @@media (max-width: 480px){.dashboard-header{padding:.75rem}.header-greeting h2{font-size:.95rem}.header-greeting p{font-size:.75rem}.stat-card{border-radius:14px}.stat-card-body .stat-value{font-size:1.8rem}.stat-icon{width:40px;height:40px}.transactions-actions{flex-direction:column;width:100%}.chart-container{height:220px}.modal-body,.modal-header,.modal-footer{padding:1rem}}
