<script src="/js/transactions.js"></script>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // The transactions.js auto-starts on its own
        // This ensures it runs even after Blazor navigation
        if (firstRender)
        {
            await JS.InvokeVoidAsync("eval", @"
                if (typeof setupTxSidebar === 'function') {
                    console.log('Transactions: Blazor init - starting...');
                    setupTxSidebar();
                    renderCategoryDropdowns();
                    renderAllTransactions();
                    if (!isLiveTransactionsRunning) startLiveTransactions();
                }
            ");
        }
    }
}