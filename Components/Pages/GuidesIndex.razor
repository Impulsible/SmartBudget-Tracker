@page "/guides"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.JSInterop
@attribute [AllowAnonymous]
@inherits BasePage
@implements IDisposable
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>SmartBudget - Guides</PageTitle>

<div class="guides-page">
    <!-- Breadcrumb -->
    <div class="breadcrumb-container">
        <div class="container">
            <nav aria-label="Breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/"><i class="bi bi-house-door"></i> Home</a></li>
                    <li class="breadcrumb-item"><i class="bi bi-chevron-right"></i></li>
                    <li class="breadcrumb-item active">Guides</li>
                </ol>
            </nav>
        </div>
    </div>

    <!-- Hero -->
    <section class="guides-hero">
        <div class="container">
            <div class="guides-hero-content">
                <div class="guides-badge">📚 Learning Center</div>
                <h1>Financial <span class="gradient-text">Guides</span></h1>
                <p>Master your finances with our comprehensive guides. From budgeting basics to advanced investing strategies.</p>
            </div>
        </div>
    </section>

    <!-- Categories -->
    <section class="guide-categories">
        <div class="container">
            <div class="categories-grid">
                <div class="category-pill active" data-category="all" onclick="window.filterGuides('all')">
                    <i class="bi bi-grid-3x3-gap"></i> All Guides
                </div>
                <div class="category-pill" data-category="budgeting" onclick="window.filterGuides('budgeting')">
                    <i class="bi bi-wallet2"></i> Budgeting
                </div>
                <div class="category-pill" data-category="saving" onclick="window.filterGuides('saving')">
                    <i class="bi bi-piggy-bank"></i> Saving
                </div>
                <div class="category-pill" data-category="investing" onclick="window.filterGuides('investing')">
                    <i class="bi bi-graph-up"></i> Investing
                </div>
                <div class="category-pill" data-category="debt" onclick="window.filterGuides('debt')">
                    <i class="bi bi-exclamation-triangle"></i> Debt Management
                </div>
                <div class="category-pill" data-category="business" onclick="window.filterGuides('business')">
                    <i class="bi bi-briefcase"></i> Business Finance
                </div>
            </div>
        </div>
    </section>

    <!-- Guides Grid -->
    <section class="guides-grid-section">
        <div class="container">
            <div class="guides-grid" id="guidesGrid">
                <!-- Guide 1 -->
                <div class="guide-card" data-category="budgeting">
                    <div class="guide-image">
                        <div class="guide-icon"><i class="bi bi-wallet2"></i></div>
                        <span class="guide-level">Beginner</span>
                    </div>
                    <div class="guide-content">
                        <span class="guide-category-badge">Budgeting</span>
                        <h3>How to Create Your First Budget</h3>
                        <p>Learn the fundamentals of budgeting and take control of your finances with this step-by-step guide.</p>
                        <div class="guide-meta">
                            <span><i class="bi bi-clock"></i> 10 min read</span>
                            <span><i class="bi bi-file-text"></i> Beginner</span>
                        </div>
                        <a href="/guides/how-to-create-your-first-budget" class="guide-read-btn">Read Guide →</a>
                    </div>
                </div>

                <!-- Guide 2 -->
                <div class="guide-card" data-category="budgeting">
                    <div class="guide-image">
                        <div class="guide-icon"><i class="bi bi-percent"></i></div>
                        <span class="guide-level">Beginner</span>
                    </div>
                    <div class="guide-content">
                        <span class="guide-category-badge">Budgeting</span>
                        <h3>The 50/30/20 Budgeting Method Explained</h3>
                        <p>Discover how to allocate your income using the popular 50/30/20 rule and achieve financial balance.</p>
                        <div class="guide-meta">
                            <span><i class="bi bi-clock"></i> 8 min read</span>
                            <span><i class="bi bi-file-text"></i> Beginner</span>
                        </div>
                        <a href="/guides/50-30-20-budgeting-method" class="guide-read-btn">Read Guide →</a>
                    </div>
                </div>

                <!-- Guide 3 -->
                <div class="guide-card" data-category="saving">
                    <div class="guide-image">
                        <div class="guide-icon"><i class="bi bi-piggy-bank"></i></div>
                        <span class="guide-level">Beginner</span>
                    </div>
                    <div class="guide-content">
                        <span class="guide-category-badge">Saving</span>
                        <h3>How to Build an Emergency Fund</h3>
                        <p>A complete guide to building your emergency fund and protecting yourself from financial surprises.</p>
                        <div class="guide-meta">
                            <span><i class="bi bi-clock"></i> 12 min read</span>
                            <span><i class="bi bi-file-text"></i> Beginner</span>
                        </div>
                        <a href="/guides/how-to-build-an-emergency-fund" class="guide-read-btn">Read Guide →</a>
                    </div>
                </div>

                <!-- Guide 4 -->
                <div class="guide-card" data-category="saving">
                    <div class="guide-image">
                        <div class="guide-icon"><i class="bi bi-flag"></i></div>
                        <span class="guide-level">Intermediate</span>
                    </div>
                    <div class="guide-content">
                        <span class="guide-category-badge">Saving</span>
                        <h3>How to Save ₦1,000,000 in One Year</h3>
                        <p>Practical strategies to save your first million Naira with discipline and smart money management.</p>
                        <div class="guide-meta">
                            <span><i class="bi bi-clock"></i> 15 min read</span>
                            <span><i class="bi bi-file-text"></i> Intermediate</span>
                        </div>
                        <a href="/guides/how-to-save-1-million-naira" class="guide-read-btn">Read Guide →</a>
                    </div>
                </div>

                <!-- Guide 5 -->
                <div class="guide-card" data-category="investing">
                    <div class="guide-image">
                        <div class="guide-icon"><i class="bi bi-graph-up"></i></div>
                        <span class="guide-level">Beginner</span>
                    </div>
                    <div class="guide-content">
                        <span class="guide-category-badge">Investing</span>
                        <h3>Beginner's Guide to Investing in Nigeria</h3>
                        <p>Start your investment journey with this comprehensive guide covering stocks, bonds, and mutual funds.</p>
                        <div class="guide-meta">
                            <span><i class="bi bi-clock"></i> 20 min read</span>
                            <span><i class="bi bi-file-text"></i> Beginner</span>
                        </div>
                        <a href="/guides/beginners-guide-to-investing-nigeria" class="guide-read-btn">Read Guide →</a>
                    </div>
                </div>

                <!-- Guide 6 -->
                <div class="guide-card" data-category="investing">
                    <div class="guide-image">
                        <div class="guide-icon"><i class="bi bi-building"></i></div>
                        <span class="guide-level">Intermediate</span>
                    </div>
                    <div class="guide-content">
                        <span class="guide-category-badge">Investing</span>
                        <h3>Real Estate Investing for Nigerians</h3>
                        <p>Learn how to invest in real estate, from REITs to property ownership, and build long-term wealth.</p>
                        <div class="guide-meta">
                            <span><i class="bi bi-clock"></i> 18 min read</span>
                            <span><i class="bi bi-file-text"></i> Intermediate</span>
                        </div>
                        <a href="/guides/real-estate-investing-nigeria" class="guide-read-btn">Read Guide →</a>
                    </div>
                </div>

                <!-- Guide 7 -->
                <div class="guide-card" data-category="debt">
                    <div class="guide-image">
                        <div class="guide-icon"><i class="bi bi-exclamation-triangle"></i></div>
                        <span class="guide-level">Beginner</span>
                    </div>
                    <div class="guide-content">
                        <span class="guide-category-badge">Debt Management</span>
                        <h3>How to Get Out of Debt Fast</h3>
                        <p>Step-by-step strategies to pay off your debts and achieve financial freedom.</p>
                        <div class="guide-meta">
                            <span><i class="bi bi-clock"></i> 14 min read</span>
                            <span><i class="bi bi-file-text"></i> Beginner</span>
                        </div>
                        <a href="/guides/how-to-get-out-of-debt" class="guide-read-btn">Read Guide →</a>
                    </div>
                </div>

                <!-- Guide 8 -->
                <div class="guide-card" data-category="business">
                    <div class="guide-image">
                        <div class="guide-icon"><i class="bi bi-briefcase"></i></div>
                        <span class="guide-level">Intermediate</span>
                    </div>
                    <div class="guide-content">
                        <span class="guide-category-badge">Business Finance</span>
                        <h3>Financial Management for Small Business Owners</h3>
                        <p>Essential money management tips for Nigerian entrepreneurs to grow their businesses successfully.</p>
                        <div class="guide-meta">
                            <span><i class="bi bi-clock"></i> 16 min read</span>
                            <span><i class="bi bi-file-text"></i> Intermediate</span>
                        </div>
                        <a href="/guides/financial-management-small-business" class="guide-read-btn">Read Guide →</a>
                    </div>
                </div>

                <!-- Guide 9 -->
                <div class="guide-card" data-category="budgeting">
                    <div class="guide-image">
                        <div class="guide-icon"><i class="bi bi-phone"></i></div>
                        <span class="guide-level">Beginner</span>
                    </div>
                    <div class="guide-content">
                        <span class="guide-category-badge">Budgeting</span>
                        <h3>Using SmartBudget to Track Your Expenses</h3>
                        <p>Learn how to use SmartBudget's features to track expenses and stay on top of your finances.</p>
                        <div class="guide-meta">
                            <span><i class="bi bi-clock"></i> 8 min read</span>
                            <span><i class="bi bi-file-text"></i> Beginner</span>
                        </div>
                        <a href="/guides/using-smartbudget-track-expenses" class="guide-read-btn">Read Guide →</a>
                    </div>
                </div>

                <!-- Guide 10 -->
                <div class="guide-card" data-category="saving">
                    <div class="guide-image">
                        <div class="guide-icon"><i class="bi bi-heart"></i></div>
                        <span class="guide-level">Beginner</span>
                    </div>
                    <div class="guide-content">
                        <span class="guide-category-badge">Saving</span>
                        <h3>Financial Wellness: Reduce Money Stress</h3>
                        <p>Discover how to improve your financial wellness and reduce the stress that comes with money management.</p>
                        <div class="guide-meta">
                            <span><i class="bi bi-clock"></i> 10 min read</span>
                            <span><i class="bi bi-file-text"></i> Beginner</span>
                        </div>
                        <a href="/guides/financial-wellness-guide" class="guide-read-btn">Read Guide →</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Newsletter -->
    <section class="newsletter-section">
        <div class="container">
            <div class="newsletter-card">
                <div class="newsletter-icon"><i class="bi bi-envelope-paper"></i></div>
                <h2>Get New Guides in Your Inbox</h2>
                <p>Subscribe to receive the latest financial guides and tips from SmartBudget.</p>
                <div class="newsletter-form">
                    <input type="email" id="newsletterEmail" class="newsletter-input" placeholder="Enter your email address" />
                    <button class="newsletter-btn" onclick="window.subscribeNewsletter()">Subscribe</button>
                </div>
                <div id="newsletterMessage" style="display:none;"></div>
                <p class="newsletter-note">No spam, unsubscribe anytime. We respect your privacy.</p>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
        <div class="container">
            <div class="cta-content">
                <h2>Ready to Take Control of Your Finances?</h2>
                <p>Join over 50,000 Nigerians who use SmartBudget to track, budget, and save.</p>
                <a href="/Account/Register" class="btn-get-started">Get Started Free →</a>
            </div>
        </div>
    </section>

    <!-- ============================================
    FOOTER
    ============================================ -->
    <footer class="guides-footer">
        <div class="container">
            <div class="guides-footer-content">
                <p>&copy; @DateTime.Now.Year SmartBudget. All rights reserved.</p>
                <div class="guides-footer-links">
                    <a href="/">Home</a>
                    <a href="/about">About</a>
                    <a href="/blog">Blog</a>
                    <a href="/guides">Guides</a>
                    <a href="/privacy">Privacy</a>
                    <a href="/terms">Terms</a>
                    <a href="/cookies">Cookies</a>
                    <a href="/security">Security</a>
                    <a href="/contact">Contact</a>
                </div>
            </div>
        </div>
    </footer>
</div>

<style>
    .guides-page{background:#0B1120;min-height:100vh;padding-top:80px;font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif}
    .breadcrumb-container{padding:.75rem 0;background:transparent}
    .container{width:100%;max-width:1280px;margin:0 auto;padding:0 1rem}
    .breadcrumb{display:flex;align-items:center;gap:.5rem;list-style:none;padding:0;margin:0;flex-wrap:wrap}
    .breadcrumb-item{display:flex;align-items:center;gap:.5rem;font-size:.85rem;color:#94A3B8}
    .breadcrumb-item a{display:flex;align-items:center;gap:.4rem;color:#94A3B8;text-decoration:none;transition:all .2s ease;padding:.25rem .5rem;border-radius:6px}
    .breadcrumb-item a:hover{color:#10B981;background:rgba(16,185,129,0.08)}
    .breadcrumb-item i.bi-chevron-right{color:#64748B;font-size:.65rem}
    .breadcrumb-item.active{color:#F1F5F9;font-weight:500;padding:.25rem .5rem;background:rgba(16,185,129,0.1);border-radius:6px;border:1px solid rgba(16,185,129,0.1)}
    .guides-hero{padding:3rem 0 2rem;background:linear-gradient(135deg,#0B1120 0%,#111827 50%,#1A2332 100%);text-align:center}
    .guides-hero-content{max-width:750px;margin:0 auto}
    .guides-badge{display:inline-block;background:rgba(16,185,129,0.12);color:#10B981;padding:.4rem 1.2rem;border-radius:20px;font-size:.8rem;font-weight:600;margin-bottom:1rem;border:1px solid rgba(16,185,129,0.15)}
    .guides-hero h1{font-size:clamp(2rem,4vw,3rem);font-weight:700;color:#F1F5F9;margin-bottom:.75rem;line-height:1.2}
    .guides-hero .gradient-text{background:linear-gradient(135deg,#10B981 0%,#34D399 100%);-webkit-background-clip:text;background-clip:text;color:transparent}
    .guides-hero p{font-size:1.0625rem;color:#94A3B8;max-width:600px;margin:0 auto;line-height:1.6}
    .guide-categories{padding:1.5rem 0;background:#111827;border-top:1px solid rgba(148,163,184,0.06);border-bottom:1px solid rgba(148,163,184,0.06)}
    .categories-grid{display:flex;flex-wrap:wrap;gap:.5rem;justify-content:center;max-width:900px;margin:0 auto}
    .category-pill{display:flex;align-items:center;gap:.4rem;padding:.5rem 1.2rem;background:transparent;border:1px solid rgba(148,163,184,0.15);border-radius:20px;color:#94A3B8;font-size:.8rem;font-weight:500;cursor:pointer;font-family:'Inter',sans-serif;transition:all .3s ease;white-space:nowrap}
    .category-pill:hover{border-color:#10B981;color:#10B981}
    .category-pill.active{background:#10B981;border-color:#10B981;color:#fff}
    .category-pill i{font-size:.9rem}
    .guides-grid-section{padding:3rem 0;background:#0B1120}
    .guides-grid{display:grid;grid-template-columns:1fr;gap:1.5rem;max-width:1100px;margin:0 auto}
    .guide-card{background:#1E293B;border-radius:16px;overflow:hidden;border:1px solid rgba(148,163,184,0.08);transition:all .3s ease;display:flex;flex-direction:column}
    .guide-card:hover{transform:translateY(-4px);border-color:rgba(16,185,129,0.2);box-shadow:0 8px 30px rgba(0,0,0,0.3)}
    .guide-image{position:relative;height:140px;background:linear-gradient(135deg,#1A2332 0%,#253349 100%);display:flex;align-items:center;justify-content:center;overflow:hidden}
    .guide-icon{font-size:2.5rem;color:#10B981;opacity:.4}
    .guide-level{position:absolute;bottom:.75rem;right:.75rem;background:rgba(16,185,129,0.9);color:#fff;padding:.2rem .7rem;border-radius:20px;font-size:.6rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em}
    .guide-content{padding:1.25rem;flex:1;display:flex;flex-direction:column}
    .guide-category-badge{display:inline-block;font-size:.65rem;color:#10B981;background:rgba(16,185,129,0.1);padding:.2rem .6rem;border-radius:20px;font-weight:600;border:1px solid rgba(16,185,129,0.15);margin-bottom:.5rem;align-self:flex-start}
    .guide-content h3{font-size:1.0625rem;font-weight:700;color:#F1F5F9;margin-bottom:.5rem;line-height:1.3}
    .guide-content p{color:#94A3B8;font-size:.85rem;line-height:1.5;margin-bottom:.75rem;flex:1}
    .guide-meta{display:flex;gap:1rem;font-size:.7rem;color:#64748B;margin-bottom:.75rem}
    .guide-meta span{display:flex;align-items:center;gap:.2rem}
    .guide-meta i{color:#10B981}
    .guide-read-btn{display:inline-flex;align-items:center;gap:.3rem;color:#10B981;text-decoration:none;font-weight:600;font-size:.85rem;transition:all .3s ease;margin-top:auto}
    .guide-read-btn:hover{gap:.6rem;color:#34D399}
    .newsletter-section{padding:3rem 0;background:#111827;border-top:1px solid rgba(148,163,184,0.06);border-bottom:1px solid rgba(148,163,184,0.06)}
    .newsletter-card{max-width:600px;margin:0 auto;text-align:center;background:#1E293B;border-radius:20px;padding:2.5rem;border:1px solid rgba(148,163,184,0.08)}
    .newsletter-icon{font-size:3rem;color:#10B981;margin-bottom:1rem}
    .newsletter-card h2{font-size:1.5rem;font-weight:700;color:#F1F5F9;margin-bottom:.5rem}
    .newsletter-card p{color:#94A3B8;font-size:.9375rem;margin-bottom:1.25rem}
    .newsletter-form{display:flex;gap:.5rem;flex-wrap:wrap;justify-content:center}
    .newsletter-input{flex:1;min-width:200px;padding:.75rem 1rem;background:#0F172A;border:1px solid rgba(148,163,184,0.15);border-radius:10px;color:#F1F5F9;font-size:.875rem;font-family:'Inter',sans-serif;outline:none;transition:border-color .3s ease}
    .newsletter-input:focus{border-color:#10B981;box-shadow:0 0 0 3px rgba(16,185,129,0.1)}
    .newsletter-input::placeholder{color:#64748B}
    .newsletter-btn{padding:.75rem 1.5rem;background:linear-gradient(135deg,#10B981 0%,#059669 100%);color:#fff;border:none;border-radius:10px;font-size:.875rem;font-weight:600;cursor:pointer;font-family:'Inter',sans-serif;transition:all .3s ease;box-shadow:0 4px 12px rgba(16,185,129,0.2);white-space:nowrap}
    .newsletter-btn:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(16,185,129,0.35)}
    .newsletter-note{font-size:.7rem;color:#64748B;margin-top:.75rem}
    .newsletter-message-success{color:#34D399;font-weight:600;padding:.5rem;border-radius:8px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.2)}
    .newsletter-message-error{color:#F87171;font-weight:600;padding:.5rem;border-radius:8px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2)}
    .cta-section{padding:3rem 0;background:#0B1120;text-align:center}
    .cta-content{max-width:600px;margin:0 auto}
    .cta-content h2{font-size:clamp(1.5rem,3vw,2.2rem);font-weight:700;color:#F1F5F9;margin-bottom:.75rem}
    .cta-content p{color:#94A3B8;font-size:.9375rem;margin-bottom:1.5rem}
    .btn-get-started{display:inline-flex;align-items:center;gap:.5rem;padding:.9rem 2.5rem;background:linear-gradient(135deg,#10B981 0%,#059669 100%);color:#fff;text-decoration:none;border-radius:12px;font-size:1rem;font-weight:600;font-family:'Inter',sans-serif;transition:all .3s ease;box-shadow:0 4px 12px rgba(16,185,129,0.25);border:none;cursor:pointer;position:relative;overflow:hidden}
    .btn-get-started::before{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.2),transparent);transition:left .5s ease}
    .btn-get-started:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(16,185,129,0.35);color:#fff}
    .btn-get-started:hover::before{left:100%}
    .no-results{grid-column:1/-1;text-align:center;padding:3rem;color:#64748B;background:#1E293B;border-radius:16px;border:1px solid rgba(148,163,184,0.08)}
    .no-results i{font-size:2rem;display:block;margin-bottom:1rem;color:#10B981}
    .no-results p{margin-bottom:.5rem}
    .no-results p:first-of-type{font-size:1rem;font-weight:600;color:#F1F5F9}
    
    /* ============================================
    FOOTER
    ============================================ */
    .guides-footer {
        padding: 1.5rem 0;
        background: #0B1120;
        border-top: 1px solid rgba(148, 163, 184, 0.06);
    }

    .guides-footer-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .guides-footer-content p {
        color: #64748B;
        font-size: 0.8rem;
        margin: 0;
    }

    .guides-footer-links {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .guides-footer-links a {
        color: #64748B;
        text-decoration: none;
        font-size: 0.8rem;
        transition: color 0.2s ease;
    }

    .guides-footer-links a:hover {
        color: #10B981;
    }

    /* ============================================
    RESPONSIVE
    ============================================ */
    @@media(min-width:768px){.guides-grid{grid-template-columns:repeat(2,1fr)}.categories-grid{gap:.75rem}}
    @@media(min-width:992px){.guides-grid{grid-template-columns:repeat(3,1fr)}}
    @@media(max-width:768px){
        .guides-page{padding-top:70px}
        .guides-hero{padding:2rem 0 1.5rem}
        .guides-grid-section{padding:2rem 0}
        .guide-image{height:120px}
        .guide-content{padding:1rem}
        .category-pill{font-size:.7rem;padding:.4rem .8rem}
        .newsletter-card{padding:1.5rem}
        .newsletter-form{flex-direction:column}
        .newsletter-input{min-width:auto;width:100%}
        .newsletter-btn{width:100%}
        .cta-section{padding:2rem 0}
        .btn-get-started{padding:.8rem 2rem;font-size:.9rem}
        .breadcrumb-item{font-size:.75rem}
        .guides-footer-content{flex-direction:column;text-align:center}
        .guides-footer-links{justify-content:center}
    }
    @@media(max-width:480px){
        .guides-hero h1{font-size:1.8rem}
        .guides-grid{grid-template-columns:1fr}
        .guide-image{height:100px}
        .guide-content h3{font-size:.95rem}
        .btn-get-started{padding:.7rem 1.5rem;font-size:.85rem}
        .category-pill{font-size:.65rem;padding:.3rem .6rem}
        .breadcrumb-item.active{font-size:.7rem;padding:.15rem .4rem}
        .breadcrumb-item a span{display:none}
        .breadcrumb-item a i{font-size:1rem}
        .guides-footer-links{gap:1rem}
        .guides-footer-links a{font-size:.7rem}
    }
</style>

<script src="/js/guides.js"></script>

@code {
    protected override async Task OnInitializedAsync()
    {
        PageName = "guides";
        await base.OnInitializedAsync();
    }

    public void Dispose()
    {
        try
        {
            JS.InvokeVoidAsync("destroyPage", "guides");
        }
        catch
        {
            // Ignore disposal errors
        }
    }
}