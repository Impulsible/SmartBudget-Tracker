<script>
    // ============================================
    // CAREERS PAGE JAVASCRIPT
    // ============================================
    console.log('Careers Page JS: Loaded');

    // ============================================
    // OPEN JOB APPLICATION
    // ============================================
    window.openJobApplication = function(position) {
        // Show a professional application modal/alert
        var message = 'Thank you for your interest in the ' + position + ' position!\n\n' +
                      'To apply, please send your CV and portfolio to:\n' +
                      '📧 careers@smartbudget.com\n\n' +
                      'Please include:\n' +
                      '• Your updated CV/Resume\n' +
                      '• A brief cover letter\n' +
                      '• Portfolio or GitHub link (if applicable)\n\n' +
                      'We\'ll review your application and get back to you within 3-5 business days.\n\n' +
                      'Good luck! 🚀';
        
        alert(message);
        
        // Track application click (for analytics)
        console.log('📝 Job application opened for:', position);
        
        // You can also log to your analytics service here
        if (typeof gtag !== 'undefined') {
            gtag('event', 'job_application_click', {
                'event_category': 'Careers',
                'event_label': position
            });
        }
    };

    // ============================================
    // SMOOTH SCROLL FOR CTA BUTTON
    // ============================================
    document.addEventListener('DOMContentLoaded', function() {
        var ctaBtn = document.querySelector('.btn-get-started');
        if (ctaBtn) {
            ctaBtn.addEventListener('click', function(e) {
                var targetId = this.getAttribute('href');
                if (targetId && targetId.startsWith('#')) {
                    e.preventDefault();
                    var target = document.querySelector(targetId);
                    if (target) {
                        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    }
                }
            });
        }
    });

    // ============================================
    // REGISTER WITH PAGE REGISTRY
    // ============================================
    if (window.pageRegistry) {
        window.pageRegistry.register('careers', {
            init: function() {
                console.log('💼 Careers page initialized');
            },
            destroy: function() {
                console.log('🗑️ Careers: Cleanup');
            },
            refresh: function() {
                console.log('🔄 Careers: Refresh');
            }
        });
    }

    // Expose functions globally
    window.openJobApplication = window.openJobApplication;

    console.log('✅ Careers Page JS: Loaded');
</script>

