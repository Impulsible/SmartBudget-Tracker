</style>

<script>
    // ============================================
    // HELP PAGE JAVASCRIPT - FIXED VERSION
    // ============================================
    console.log('Help Page JS: Loaded');

    // ============================================
    // TOGGLE ARTICLE EXPAND - INDEPENDENT
    // ============================================
    window.toggleArticle = function(element) {
        var card = element;
        var btn = card.querySelector('.btn-toggle-article');
        var span = btn ? btn.querySelector('span') : null;
        var icon = btn ? btn.querySelector('i') : null;
        
        if (card.classList.contains('expanded')) {
            card.classList.remove('expanded');
            if (span) span.textContent = 'Read Article';
            if (icon) {
                icon.className = 'bi bi-chevron-down';
            }
        } else {
            card.classList.add('expanded');
            if (span) span.textContent = 'Close Article';
            if (icon) {
                icon.className = 'bi bi-chevron-up';
            }
        }
    };

    // ============================================
    // SEARCH HELP ARTICLES
    // ============================================
    window.searchHelp = function() {
        var searchInput = document.getElementById('helpSearch');
        var searchTerm = searchInput.value.toLowerCase().trim();
        var articles = document.querySelectorAll('.article-card');
        var categories = document.querySelectorAll('.category-card');
        
        categories.forEach(function(cat) {
            cat.classList.remove('active');
        });
        var allCat = document.querySelector('.category-card[data-category="all"]');
        if (allCat) allCat.classList.add('active');
        
        if (searchTerm === '') {
            articles.forEach(function(article) {
                article.style.display = 'block';
            });
            var grid = document.getElementById('helpArticles');
            var noResults = grid.querySelector('.no-results');
            if (noResults) noResults.remove();
            
            articles.forEach(function(article) {
                article.classList.remove('expanded');
                var btn = article.querySelector('.btn-toggle-article');
                if (btn) {
                    var span = btn.querySelector('span');
                    var icon = btn.querySelector('i');
                    if (span) span.textContent = 'Read Article';
                    if (icon) icon.className = 'bi bi-chevron-down';
                }
            });
            return;
        }
        
        var hasResults = false;
        articles.forEach(function(article) {
            var title = article.querySelector('h3')?.textContent.toLowerCase() || '';
            var category = article.querySelector('.article-category')?.textContent.toLowerCase() || '';
            var content = article.querySelector('.article-content')?.textContent.toLowerCase() || '';
            
            article.classList.remove('expanded');
            var btn = article.querySelector('.btn-toggle-article');
            if (btn) {
                var span = btn.querySelector('span');
                var icon = btn.querySelector('i');
                if (span) span.textContent = 'Read Article';
                if (icon) icon.className = 'bi bi-chevron-down';
            }
            
            if (title.includes(searchTerm) || category.includes(searchTerm) || content.includes(searchTerm)) {
                article.style.display = 'block';
                hasResults = true;
            } else {
                article.style.display = 'none';
            }
        });
        
        var grid = document.getElementById('helpArticles');
        var noResults = grid.querySelector('.no-results');
        if (!hasResults) {
            if (!noResults) {
                var msg = document.createElement('div');
                msg.className = 'no-results';
                msg.innerHTML = '<i class="bi bi-search"></i><p>No articles found</p><p>Try a different search term or browse our categories above.</p>';
                grid.appendChild(msg);
            }
        } else {
            if (noResults) {
                noResults.remove();
            }
        }
    };

    // ============================================
    // FILTER BY CATEGORY
    // ============================================
    window.filterHelp = function(category) {
        var articles = document.querySelectorAll('.article-card');
        var searchInput = document.getElementById('helpSearch');
        var categories = document.querySelectorAll('.category-card');
        
        if (searchInput) {
            searchInput.value = '';
        }
        
        categories.forEach(function(cat) {
            cat.classList.remove('active');
            var catName = cat.getAttribute('data-category');
            if (catName === category) {
                cat.classList.add('active');
            }
        });
        
        articles.forEach(function(article) {
            article.classList.remove('expanded');
            var btn = article.querySelector('.btn-toggle-article');
            if (btn) {
                var span = btn.querySelector('span');
                var icon = btn.querySelector('i');
                if (span) span.textContent = 'Read Article';
                if (icon) icon.className = 'bi bi-chevron-down';
            }
        });
        
        var hasResults = false;
        articles.forEach(function(article) {
            var articleCategory = article.dataset.category || '';
            if (category === 'all' || articleCategory === category) {
                article.style.display = 'block';
                hasResults = true;
            } else {
                article.style.display = 'none';
            }
        });
        
        var grid = document.getElementById('helpArticles');
        var noResults = grid.querySelector('.no-results');
        if (noResults) {
            noResults.remove();
        }
        
        if (!hasResults) {
            var msg = document.createElement('div');
            msg.className = 'no-results';
            msg.innerHTML = '<i class="bi bi-folder-open"></i><p>No articles in this category</p><p>Try selecting a different category or use the search bar.</p>';
            grid.appendChild(msg);
        }
    };

    // ============================================
    // INIT
    // ============================================
    document.addEventListener('DOMContentLoaded', function() {
        var allCat = document.querySelector('.category-card[data-category="all"]');
        if (allCat) {
            allCat.classList.add('active');
        }
        console.log('❓ Help page initialized - 10 FAQ articles loaded (independent toggle)');
    });

    // ============================================
    // REGISTER WITH PAGE REGISTRY
    // ============================================
    if (window.pageRegistry) {
        window.pageRegistry.register('help', {
            init: function() {
                console.log('❓ Help page initialized');
                var allCat = document.querySelector('.category-card[data-category="all"]');
                if (allCat) allCat.classList.add('active');
            },
            destroy: function() {
                console.log('🗑️ Help: Cleanup');
            },
            refresh: function() {
                console.log('🔄 Help: Refresh');
            }
        });
    }

    // Expose functions globally
    window.toggleArticle = window.toggleArticle;
    window.searchHelp = window.searchHelp;
    window.filterHelp = window.filterHelp;

    console.log('✅ Help Page JS: Loaded with independent article toggling');
</script>

@code {
    protected override async Task OnInitializedAsync()
    {
        PageName = "help";
        await base.OnInitializedAsync();
    }

    public void Dispose()
    {
        try
        {
            JS.InvokeVoidAsync("destroyPage", "help");
        }
        catch
        {
            // Ignore disposal errors
        }
    }
}