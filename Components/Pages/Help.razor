    .no-results{grid-column:1/-1;text-align:center;padding:3rem;color:#64748B;background:#1E293B;border-radius:16px;border:1px solid rgba(148,163,184,0.08)}
    .no-results i{font-size:2rem;display:block;margin-bottom:1rem;color:#10B981}
