    /* ============================================
    RESPONSIVE
    ============================================ */
    @@media(min-width:768px){.categories-grid{grid-template-columns:repeat(2,1fr)}.articles-grid{grid-template-columns:repeat(2,1fr)}.support-options{flex-direction:row}.support-btn,.support-btn-outline{flex:1}}
    @@media(min-width:992px){.categories-grid{grid-template-columns:repeat(3,1fr)}.articles-grid{grid-template-columns:repeat(3,1fr)}}
