        .support-card{padding:1.25rem}
        .btn-get-started{padding:.7rem 1.5rem;font-size:.85rem}
        .breadcrumb-item.active{font-size:.7rem;padding:.15rem .4rem}
        .breadcrumb-item a span{display:none}
        .breadcrumb-item a i{font-size:1rem}
        .help-footer-links{gap:1rem}
        .help-footer-links a{font-size:.7rem}
