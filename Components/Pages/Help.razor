    .support-btn:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(16,185,129,0.35)}
    .support-btn-outline{display:flex;align-items:center;justify-content:center;gap:.5rem;padding:.75rem 1.5rem;background:transparent;border:1px solid rgba(148,163,184,0.2);color:#CBD5E1;border-radius:10px;font-weight:600;text-decoration:none;font-size:.875rem;transition:all .3s ease}
    .support-btn-outline:hover{border-color:#10B981;color:#10B981}
