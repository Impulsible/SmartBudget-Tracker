@code {
    // ============================================
    // PAGE INITIALIZATION
    // ============================================
    
    protected override async Task OnInitializedAsync()
    {
        PageName = "settings";
        await base.OnInitializedAsync();
    }

    // ============================================
    // TOAST HELPERS - For showing notifications
    // ============================================
    
    private async Task ShowSuccessToast(string message)
    {
        await JS.InvokeVoidAsync("showToast", message, "success");
    }
    
    private async Task ShowErrorToast(string message)
    {
        await JS.InvokeVoidAsync("showToast", message, "error");
    }
    
    private async Task ShowInfoToast(string message)
    {
        await JS.InvokeVoidAsync("showToast", message, "info");
    }
    
    private async Task ShowWarningToast(string message)
    {
        await JS.InvokeVoidAsync("showToast", message, "warning");
    }

    // ============================================
    // EXAMPLE: Using Toasts in Blazor Code
    // ============================================
    
    private async Task ExampleSettingsOperation()
    {
        try
        {
            await ShowInfoToast("Saving settings...");
            // Your settings save logic here
            await ShowSuccessToast("Settings saved successfully! ⚙️");
        }
        catch (Exception ex)
        {
            await ShowErrorToast($"Error: {ex.Message}");
        }
    }

    // ============================================
    // CLEANUP
    // ============================================
    
    public void Dispose()
    {
        try
        {
            JS.InvokeVoidAsync("destroyPage", "settings");
        }
        catch
        {
            // Ignore disposal errors
        }
    }
}