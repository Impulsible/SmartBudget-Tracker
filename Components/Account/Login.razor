@page "/Account/Login"

<PageTitle>SmartBudget - Sign In</PageTitle>

<div class="auth-page">
    <a href="/" class="back-to-home">
        <i class="bi bi-arrow-left"></i>
        <span>Back to Home</span>
    </a>

    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header">
                <a href="/" class="auth-logo">
                    <div class="logo-icon-wrapper"><i class="bi bi-piggy-bank"></i></div>
                    <h2>SmartBudget</h2>
                </a>
                <p class="auth-subtitle">Welcome back! Please enter your details</p>
            </div>

            <div id="errorMessageDiv" style="display:none;" class="alert alert-error">
                <div class="alert-icon"><i class="bi bi-exclamation-triangle-fill"></i></div>
                <div class="alert-content"><strong>Login Failed</strong><span id="errorText"></span></div>
            </div>

            <div class="auth-form">
                <div class="form-group">
                    <label class="form-label"><span class="label-icon"><i class="bi bi-envelope"></i></span>Email Address</label>
                    <input type="email" id="loginEmail" class="form-control" placeholder="you@example.com" autocomplete="email" />
                </div>

                <div class="form-group">
                    <label class="form-label"><span class="label-icon"><i class="bi bi-lock"></i></span>Password</label>
                    <div class="input-wrapper">
                        <input type="password" id="loginPassword" class="form-control" placeholder="Enter your password" autocomplete="current-password" />
                        <button type="button" class="password-toggle" onclick="toggleLoginPassword()" tabindex="-1">
                            <i id="loginEyeIcon" class="bi bi-eye"></i>
                        </button>
                    </div>
                    <div class="forgot-password">
                        <a href="/Account/ForgotPassword" class="forgot-link">Forgot password?</a>
                    </div>
                </div>

                <div class="form-group remember-group">
                    <label class="checkbox-label">
                        <input type="checkbox" id="rememberMeCheckbox" checked />
                        <span class="checkmark"></span>
                        <span class="terms-text">Remember me on this device</span>
                    </label>
                </div>

                <button type="button" class="btn-auth btn-primary" id="loginBtn">
                    <span>Sign In</span>
                    <i class="bi bi-arrow-right"></i>
                </button>
            </div>

            <div class="auth-footer">
                <p>Don't have an account? <a href="/Account/Register" class="auth-link">Create free account</a></p>
            </div>
        </div>

        <div class="auth-banner">
            <div class="banner-pattern"></div>
            <div class="banner-content">
                <div class="banner-icon"><i class="bi bi-graph-up"></i></div>
                <h3>Track your finances effortlessly</h3>
                <p>Join over 50,000+ users who trust SmartBudget to manage their money.</p>
                <div class="banner-stats">
                    <div class="stat-item"><span class="stat-value">50k+</span><span class="stat-label">Active Users</span></div>
                    <div class="stat-divider"></div>
                    <div class="stat-item"><span class="stat-value">₦20B+</span><span class="stat-label">Tracked</span></div>
                    <div class="stat-divider"></div>
                    <div class="stat-item"><span class="stat-value">95%</span><span class="stat-label">Satisfaction</span></div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .auth-page{min-height:100vh;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#0B1120,#111827 50%,#1A2332);position:relative;overflow:hidden;padding:2rem}
    .auth-page::before{content:'';position:absolute;top:0;left:0;right:0;bottom:0;background:radial-gradient(circle at 20% 80%,rgba(16,185,129,0.06),transparent 50%),radial-gradient(circle at 80% 20%,rgba(16,185,129,0.04),transparent 50%);pointer-events:none}
    .back-to-home{position:fixed;top:1.5rem;left:1.5rem;display:inline-flex;align-items:center;gap:0.5rem;color:#94A3B8;text-decoration:none;font-size:0.875rem;font-weight:500;padding:0.5rem 1rem;border-radius:8px;background:rgba(30,41,59,0.8);border:1px solid rgba(148,163,184,0.15);transition:all 0.2s;z-index:100;backdrop-filter:blur(10px)}
    .back-to-home:hover{color:#10B981;background:rgba(30,41,59,1);border-color:#10B981;transform:translateX(-4px)}.back-to-home i{font-size:1rem}
    .auth-container{display:grid;grid-template-columns:1fr 1fr;max-width:1100px;width:100%;background:rgba(30,41,59,0.7);backdrop-filter:blur(20px);border-radius:24px;overflow:hidden;box-shadow:0 25px 50px -12px rgba(0,0,0,0.5),0 0 0 1px rgba(148,163,184,0.1);position:relative;z-index:1}
    .auth-card{padding:3rem 2.5rem;background:#1E293B;display:flex;flex-direction:column;justify-content:center}
    .auth-header{margin-bottom:2rem}.auth-logo{display:flex;align-items:center;gap:1rem;margin-bottom:0.5rem;text-decoration:none}.auth-logo:hover{opacity:0.9}
    .logo-icon-wrapper{width:44px;height:44px;background:linear-gradient(135deg,#10B981,#059669);border-radius:12px;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 12px rgba(16,185,129,0.3)}
    .logo-icon-wrapper i{font-size:24px;color:white}.auth-logo h2{font-size:1.75rem;font-weight:700;color:#F1F5F9;margin:0}
    .auth-subtitle{color:#94A3B8;font-size:0.9375rem;margin-top:0.25rem}
    .alert{display:flex;gap:1rem;padding:1rem 1.25rem;border-radius:12px;margin-bottom:1.5rem;align-items:flex-start}
    .alert-icon{font-size:1.25rem}.alert-content{display:flex;flex-direction:column;gap:0.25rem}
    .alert-content strong{font-size:0.875rem;font-weight:600}.alert-content span{font-size:0.8125rem}
    .alert-error{background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2);color:#FCA5A5}.alert-error strong{color:#EF4444}
    .auth-form{display:flex;flex-direction:column;gap:1.25rem}.form-group{margin:0}
    .form-label{display:flex;align-items:center;gap:0.5rem;font-size:0.8125rem;font-weight:600;color:#CBD5E1;margin-bottom:0.5rem}.label-icon{color:#10B981;font-size:1rem}
    .form-control{width:100%;padding:0.75rem 1rem;background:#0F172A;border:1px solid rgba(148,163,184,0.15);border-radius:10px;color:#F1F5F9;font-size:0.9375rem;outline:none;font-family:'Inter',sans-serif}
    .form-control:focus{border-color:#10B981;box-shadow:0 0 0 3px rgba(16,185,129,0.1)}.form-control::placeholder{color:#64748B}
    .input-wrapper{position:relative}.input-wrapper .form-control{padding-right:3rem}
    .password-toggle{position:absolute;right:8px;top:50%;transform:translateY(-50%);background:transparent;border:none;color:#64748B;cursor:pointer;padding:0.5rem;border-radius:6px;transition:all 0.2s;z-index:5}
    .password-toggle:hover{color:#CBD5E1;background:rgba(148,163,184,0.1)}.password-toggle i{font-size:1.125rem;pointer-events:none}
    .forgot-password{margin-top:0.5rem;text-align:right}.forgot-link{color:#10B981;text-decoration:none;font-size:0.75rem}
    .remember-group{margin:0.5rem 0}
    .checkbox-label{display:flex;align-items:flex-start;gap:0.75rem;cursor:pointer;font-size:0.8125rem;color:#94A3B8;position:relative;padding-left:2rem}
    .checkbox-label input[type="checkbox"]{position:absolute;opacity:0;height:0;width:0}
    .checkmark{position:absolute;left:0;top:2px;height:20px;width:20px;background:#0F172A;border:2px solid rgba(148,163,184,0.3);border-radius:6px}
    .checkbox-label:hover .checkmark{border-color:#10B981}.checkbox-label input:checked~.checkmark{background:#10B981;border-color:#10B981}
    .checkmark::after{content:"";position:absolute;display:none;left:6px;top:2px;width:5px;height:10px;border:solid white;border-width:0 2px 2px 0;transform:rotate(45deg)}
    .checkbox-label input:checked~.checkmark::after{display:block}
    .btn-auth{display:flex;align-items:center;justify-content:center;gap:0.5rem;width:100%;padding:0.875rem;border:none;border-radius:12px;font-size:0.9375rem;font-weight:600;cursor:pointer;font-family:'Inter',sans-serif;margin-top:0.5rem}
    .btn-primary{background:linear-gradient(135deg,#10B981,#059669);color:white;box-shadow:0 4px 12px rgba(16,185,129,0.2)}
    .btn-primary:hover{transform:translateY(-1px);box-shadow:0 8px 20px rgba(16,185,129,0.3)}.btn-primary:disabled{opacity:0.7;cursor:not-allowed}
    .spinner-sm{width:18px;height:18px;border:2px solid rgba(255,255,255,0.3);border-top-color:white;border-radius:50%;animation:spin 0.6s linear infinite;display:inline-block}
    .auth-footer{margin-top:2rem;text-align:center;padding-top:1.5rem;border-top:1px solid rgba(148,163,184,0.1)}
    .auth-footer p{color:#94A3B8;font-size:0.875rem}.auth-link{color:#10B981;text-decoration:none;font-weight:600}.auth-link:hover{color:#34D399}
    .auth-banner{background:linear-gradient(135deg,#0F172A,#1E293B);padding:3rem 2.5rem;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden}
    .banner-pattern{position:absolute;top:0;left:0;right:0;bottom:0;background-image:radial-gradient(circle at 20% 50%,rgba(16,185,129,0.08) 1px,transparent 1px);background-size:24px 24px}
    .banner-content{position:relative;z-index:1;max-width:420px;color:white}
    .banner-icon{width:60px;height:60px;background:rgba(16,185,129,0.15);border-radius:16px;display:flex;align-items:center;justify-content:center;margin-bottom:1.5rem;border:1px solid rgba(16,185,129,0.2)}
    .banner-icon i{font-size:28px;color:#10B981}.banner-content h3{font-size:1.75rem;font-weight:700;margin-bottom:0.75rem}
    .banner-content>p{font-size:0.875rem;color:rgba(255,255,255,0.7);margin-bottom:2rem}
    .banner-stats{display:flex;align-items:center;justify-content:center;gap:1.5rem;padding:1rem 1.5rem;background:rgba(255,255,255,0.08);border-radius:16px;margin-bottom:2rem;border:1px solid rgba(255,255,255,0.1)}
    .stat-item{text-align:center;flex:1}.stat-value{display:block;font-size:1.5rem;font-weight:700;color:white}.stat-label{display:block;font-size:0.6875rem;color:rgba(255,255,255,0.7);text-transform:uppercase}.stat-divider{width:1px;height:30px;background:rgba(255,255,255,0.15)}
    @@keyframes spin{to{transform:rotate(360deg)}}
    @@media (max-width:968px){.auth-container{grid-template-columns:1fr;max-width:500px}.auth-banner{display:none}.auth-card{padding:2.5rem 2rem}.back-to-home{top:1rem;left:1rem}}
    @@media (max-width:768px){.auth-page{padding:1rem}.auth-card{padding:2rem 1.5rem}.auth-logo h2{font-size:1.5rem}}
    @@media (max-width:480px){.auth-card{padding:1.5rem 1.25rem}.back-to-home span{display:none}.back-to-home{padding:0.5rem}}
</style>

<script src="js/login.js"></script>