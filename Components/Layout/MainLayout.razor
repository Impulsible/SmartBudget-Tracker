@inherits LayoutComponentBase
@inject NavigationManager NavigationManager

<PageTitle>SmartBudget</PageTitle>

<!-- PWA Meta Tags -->
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="SmartBudget">
<link rel="apple-touch-icon" href="/icons/icon-192x192.png">
<link rel="manifest" href="/manifest.json">

<div class="page">
    <main>
        @Body
    </main>
</div>

<script>
    // ============================================
    // SERVICE WORKER REGISTRATION
    // ============================================
    if ('serviceWorker' in navigator) {
        window.addEventListener('load', function() {
            navigator.serviceWorker.register('/sw.js')
                .then(function(registration) {
                    console.log('✅ Service Worker registered:', registration);
                })
                .catch(function(error) {
                    console.log('❌ Service Worker registration failed:', error);
                });
        });
    }
</script>

<script src="/js/install.js"></script>

<style>
    .page {
        min-height: 100vh;
        background: transparent;
    }

    main {
        padding: 0 !important;
        margin: 0;
        min-height: 100vh;
    }

    /* Install banner animation styles */
    @@keyframes slideUpBanner {
        from { transform: translateY(100%); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }

    @@keyframes slideDownBanner {
        from { transform: translateY(0); opacity: 1; }
        to { transform: translateY(100%); opacity: 0; }
    }

    .piggy-icon {
        width: 48px;
        height: 48px;
        background: linear-gradient(135deg, #10B981 0%, #059669 100%);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        color: white;
        box-shadow: 0 4px 12px rgba(16,185,129,0.3);
        flex-shrink: 0;
    }
    .piggy-icon svg {
        width: 28px;
        height: 28px;
        fill: white;
    }

    /* Toast notification styles */
    .toast-container {
        position: fixed;
        top: 20px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 10001;
        width: 90%;
        max-width: 420px;
    }

    .toast-notification {
        background: #1E293B;
        border-left: 4px solid #10B981;
        padding: 0.75rem 1.5rem;
        border-radius: 12px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.4);
        color: #F1F5F9;
        font-size: 0.95rem;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-family: 'Inter', sans-serif;
        margin-bottom: 0.5rem;
        animation: slideDownBanner 0.5s ease;
    }
</style>

@code {
    protected override void OnInitialized()
    {
        // ✅ Force full page reload for ALL navigation
        NavigationManager.LocationChanged += OnLocationChanged!;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        // Force full page reload on every navigation
        if (!e.IsNavigationIntercepted)
        {
            NavigationManager.NavigateTo(e.Location, true);
        }
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged!;
    }
}